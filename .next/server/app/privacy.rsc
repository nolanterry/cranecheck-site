8:["$","$1","c",{"children":[[["$","$L10",null,{}],["$","main",null,{"id":"main-content","className":"py-20 bg-white","children":["$","article",null,{"className":"max-w-3xl mx-auto px-4 prose prose-gray","children":[["$","h1",null,{"children":"Privacy Policy"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last updated: March 15, 2026"}],["$","p",null,{"children":"CraneCheck (\"we,\" \"us,\" or \"our\") operates the CraneCheck crane inspection compliance platform. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our website and application."}],["$","h2",null,{"children":"1. Information We Collect"}],["$","h3",null,{"children":"Information You Provide"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account information:"}]," Name, email address, company name, phone number, and job title when you create an account or request a demo."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Inspection data:"}]," Crane inspection records, photos, deficiency notes, equipment details, and compliance documentation you enter into the platform."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payment information:"}]," Billing address and payment method details, processed securely by our payment processor (Stripe). We do not store full credit card numbers."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications:"}]," Messages you send through our contact form, support tickets, or email correspondence."]}]]}],["$","h3",null,{"children":"Information Collected Automatically"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Usage data:"}]," Pages visited, features used, inspection completion patterns, and session duration."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Device information:"}]," Browser type, operating system, device type, screen resolution, and IP address."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cookies and similar technologies:"}]," We use essential cookies for authentication and optional analytics cookies to improve our service."]}]]}],["$","h2",null,{"children":"2. How We Use Your Information"}],["$","ul",null,{"children":[["$","li",null,{"children":"Provide, maintain, and improve the CraneCheck platform"}],["$","li",null,{"children":"Process transactions and send related information (receipts, invoices)"}],["$","li",null,{"children":"Send technical notices, updates, security alerts, and support messages"}],["$","li",null,{"children":"Respond to your comments, questions, and support requests"}],["$","li",null,{"children":"Monitor and analyze usage trends to improve user experience"}],["$","li",null,{"children":"Detect, prevent, and address technical issues and fraud"}],["$","li",null,{"children":"Send marketing communications (with your consent; you can opt out anytime)"}]]}],["$","h2",null,{"children":"3. Data Sharing and Disclosure"}],["$","p",null,{"children":"We do not sell your personal information. We may share data with:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Service providers:"}]," Third-party vendors who assist in operating our platform (hosting, payment processing, email delivery, analytics)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal compliance:"}]," When required by law, regulation, or legal process."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Business transfers:"}]," In connection with a merger, acquisition, or sale of assets."]}],["$","li",null,{"children":[["$","strong",null,{"children":"With your consent:"}]," When you explicitly authorize sharing."]}]]}],["$","h2",null,{"children":"4. Data Security"}],["$","p",null,{"children":"We implement industry-standard security measures including encryption in transit (TLS 1.2+), encryption at rest, access controls, and regular security assessments. Inspection data and compliance records are stored in SOC 2-compliant infrastructure."}],"$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b"]}]}],"$L1c"],["$L1d"],"$L1e"]}]
