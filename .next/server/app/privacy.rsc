12:["$","p",null,{"children":"We retain your account information and inspection data for as long as your account is active or as needed to provide services. Inspection records may be retained longer to support OSHA compliance requirements (typically 5+ years per 29 CFR 1926.1412). You may request deletion of your data at any time, subject to legal retention requirements."}]
13:["$","h2",null,{"children":"6. Your Rights"}]
14:["$","p",null,{"children":"Depending on your jurisdiction, you may have the right to:"}]
15:["$","ul",null,{"children":[["$","li",null,{"children":"Access the personal data we hold about you"}],["$","li",null,{"children":"Correct inaccurate or incomplete data"}],["$","li",null,{"children":"Request deletion of your data"}],["$","li",null,{"children":"Object to or restrict processing of your data"}],["$","li",null,{"children":"Export your data in a portable format"}],["$","li",null,{"children":"Withdraw consent for marketing communications"}]]}]
16:["$","h2",null,{"children":"7. Children's Privacy"}]
17:["$","p",null,{"children":"CraneCheck is not intended for use by individuals under 18 years of age. We do not knowingly collect personal information from children."}]
18:["$","h2",null,{"children":"8. Changes to This Policy"}]
19:["$","p",null,{"children":"We may update this Privacy Policy from time to time. We will notify you of material changes by posting the updated policy on this page and updating the \"Last updated\" date."}]
