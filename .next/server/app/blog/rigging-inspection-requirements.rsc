16:["$","ul",null,{"children":[["$","li",null,{"children":"Wire rope slings (1926.251(c))"}],["$","li",null,{"children":"Natural and synthetic fiber rope slings (1926.251(d))"}],["$","li",null,{"children":"Synthetic web slings (1926.251(e))"}],["$","li",null,{"children":"Chain slings (1926.251(f))"}],["$","li",null,{"children":"Shackles and hardware (1926.251(b))"}]]}]
17:["$","p",null,{"children":["The overarching requirement in 1926.251(a)(1) is simple: ",["$","strong",null,{"children":"rigging equipment shall be inspected prior to use on each shift and as necessary during its use to ensure that it is safe."}]," Defective rigging must be immediately removed from service."]}]
18:["$","h2",null,{"children":"Pre-Use Inspection: Every Shift, Every Sling"}]
19:["$","p",null,{"children":"Before using any sling or rigging hardware, a competent person must perform a visual inspection. This is not a suggestion — it is a federal requirement that applies to every shift. Here is what to inspect for each type:"}]
1a:["$","h3",null,{"children":"Wire Rope Slings"}]
1b:["$","ul",null,{"children":[["$","li",null,{"children":"Broken wires — 10 randomly distributed in one rope lay, or 5 in one strand in one lay = remove from service"}],["$","li",null,{"children":"Severe corrosion, pitting, or rust that reduces wire diameter"}],["$","li",null,{"children":"Kinking, crushing, bird-caging, or other distortion of the rope structure"}],["$","li",null,{"children":"End fittings — cracked, deformed, or worn sockets, thimbles, splices"}],["$","li",null,{"children":"Heat damage — discoloration from welding, torch cutting, or electrical contact"}],["$","li",null,{"children":"Core protrusion or separation"}],["$","li",null,{"children":"Reduction in rope diameter exceeding 5% (measured at the smallest point)"}]]}]
1c:["$","h3",null,{"children":"Synthetic Web Slings"}]
1d:["$","ul",null,{"children":[["$","li",null,{"children":"Acid or caustic burns — any visible damage from chemical exposure"}],["$","li",null,{"children":"Melting or charring of any part of the sling surface"}],["$","li",null,{"children":"Snags, punctures, tears, or cuts"}],["$","li",null,{"children":"Broken or worn stitching in load-bearing splices"}],["$","li",null,{"children":"Knots in any part of the sling"}],["$","li",null,{"children":"Excessive abrasive wear — exposed core yarns"}],["$","li",null,{"children":"Fittings — distorted, cracked, or pitted hooks, rings, links, or end attachments"}],["$","li",null,{"children":[["$","strong",null,{"children":"Missing or illegible sling identification tag"}]," — if you cannot read the rated capacity, the sling must not be used"]}]]}]
1e:["$","h3",null,{"children":"Chain Slings"}]
1f:["$","ul",null,{"children":[["$","li",null,{"children":"Stretch — any chain link stretched beyond 5% of its original length = immediate removal"}],["$","li",null,{"children":"Wear — link cross-section reduced by more than 10% at any point"}],["$","li",null,{"children":"Nicks, gouges, or cracks in any link"}],["$","li",null,{"children":"Bent or twisted links"}],["$","li",null,{"children":"Heat damage — any evidence of exposure to temperatures above manufacturer limits"}],["$","li",null,{"children":"Weld splatter — indicates unauthorized field repair"}]]}]
20:["$","h3",null,{"children":"Shackles and Hardware"}]
21:["$","ul",null,{"children":[["$","li",null,{"children":"Deformation — any visible bending or distortion of the bow or pin"}],["$","li",null,{"children":"Cracks — use dye penetrant or magnetic particle testing if suspected"}],["$","li",null,{"children":"Corrosion or pitting that reduces cross-section"}],["$","li",null,{"children":"Pin wear — excessive play between pin and bow"}],["$","li",null,{"children":"Thread damage on screw-pin shackles"}],["$","li",null,{"children":"Missing or illegible rated load markings"}],["$","li",null,{"children":"Unauthorized modifications — welding, drilling, grinding"}]]}]
22:["$","h2",null,{"children":"Periodic (Thorough) Inspections"}]
23:["$","p",null,{"children":"Beyond pre-use visual inspections, ASME B30.9 requires periodic thorough inspections at intervals based on:"}]
24:["$","ul",null,{"children":[["$","li",null,{"children":"Frequency of use"}],["$","li",null,{"children":"Severity of service conditions"}],["$","li",null,{"children":"Nature of lifts being made"}],["$","li",null,{"children":"Experience gained on the service life of slings used in similar circumstances"}]]}]
25:["$","p",null,{"children":"For slings in regular daily use, periodic inspections should be conducted at least annually. For severe service (high frequency, near-capacity loads, corrosive environments), quarterly periodic inspections are recommended."}]
26:["$","p",null,{"children":"Periodic inspections must be documented. Records should include: sling identification number, date, inspector name and qualifications, items inspected, condition, and disposition (returned to service, repaired, or removed from service)."}]
27:["$","h2",null,{"children":"Removal from Service Criteria"}]
28:["$","p",null,{"children":["OSHA and ASME are clear: defective rigging must be ",["$","strong",null,{"children":"immediately removed from service"}],". There is no \"use it one more time\" exception. Specific removal criteria by type:"]}]
29:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Wire rope slings:"}]," 10+ broken wires per lay, 5% diameter reduction, kinking, core protrusion, heat damage, end fitting damage"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Web slings:"}]," acid burns, melting, snags exposing core, worn stitching, missing capacity tag, knots"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Chain slings:"}]," 5% stretch, 10% wear, cracks, gouges, heat damage, unauthorized repairs"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Shackles:"}]," any visible deformation, cracks, excessive pin wear, missing load rating"]}]]}]
2a:["$","p",null,{"children":"Removed equipment should be physically tagged \"DO NOT USE\" and segregated until it is either repaired by the manufacturer (or a qualified person) and re-certified, or destroyed. Cutting web slings and bending hooks open are common destruction methods that prevent re-use."}]
2b:["$","h2",null,{"children":"Documentation That Protects You"}]
2c:["$","p",null,{"children":"Rigging inspection records serve two purposes: regulatory compliance and legal defense. If a rigging failure causes an injury, the first question will be: \"When was this equipment last inspected, and by whom?\""}]
2d:["$","p",null,{"children":"Your documentation system should track:"}]
2e:["$","ul",null,{"children":[["$","li",null,{"children":"Every sling and piece of rigging hardware by unique ID"}],["$","li",null,{"children":"Pre-use inspection completion (date, inspector, pass/fail)"}],["$","li",null,{"children":"Periodic inspection results with detailed findings"}],["$","li",null,{"children":"Removal from service records (reason, date, disposition)"}],["$","li",null,{"children":"Photos of deficiencies found during inspection"}],["$","li",null,{"children":"Corrective actions taken and verified"}]]}]
2f:["$","p",null,{"children":["Managing this on paper across a fleet of hundreds of slings is impractical. ",["$","$Lf",null,{"href":"/pricing","children":"CraneCheck"}]," tracks rigging equipment alongside your crane fleet — same inspection workflow, same photo documentation, same audit trail. Every sling has a history. Every inspection is recorded. Every deficiency is tracked to resolution."]}]
30:["$","h2",null,{"children":"Key Takeaways"}]
31:["$","ul",null,{"children":[["$","li",null,{"children":"OSHA 1926.251 requires rigging inspection before every shift — this is not optional"}],["$","li",null,{"children":"Each sling type (wire rope, web, chain) has specific removal-from-service criteria — know them"}],["$","li",null,{"children":"Shackles and hardware must be inspected for deformation, cracks, and legible load ratings"}],["$","li",null,{"children":"Periodic thorough inspections must be documented with inspector qualifications"}],["$","li",null,{"children":"Defective rigging must be immediately removed — no exceptions, no \"one more lift\""}],["$","li",null,{"children":"Digital tracking of rigging equipment is the only practical way to maintain compliance at scale"}]]}]
