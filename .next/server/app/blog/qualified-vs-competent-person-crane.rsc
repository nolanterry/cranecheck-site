6:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Qualified Person vs. Competent Person: Who Can Inspect Your Crane?\",\"description\":\"OSHA defines qualified and competent persons differently for crane inspections. Getting this wrong means your inspections are invalid. Here's exactly who can do what.\",\"datePublished\":\"2026-03-09\",\"dateModified\":\"2026-03-09\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/qualified-vs-competent-person-crane\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Qualified Person vs. Competent Person: Who Can Inspect Your Crane?\",\"item\":\"https://cranecheck.com/blog/qualified-vs-competent-person-crane\"}]}"}}],["$","$Lc",null,{}],["$","main",null,{"children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Compliance"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 9, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"9 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"Qualified Person vs. Competent Person: Who Can Inspect Your Crane?"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl","children":"OSHA uses these terms precisely — and they don't mean the same thing. If the wrong person is signing off on your inspections, those inspections are effectively invalid. Here's who can do what."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-strong:text-navy","children":[["$","p",null,{"children":"\"Our most experienced operator does all our inspections.\" We hear this constantly from crane companies. And it's one of the most common — and costly — compliance mistakes in the industry."}],["$","p",null,{"children":["OSHA's crane standards (29 CFR 1926 Subpart CC) use two specific designations for people authorized to perform inspections and make safety determinations: ",["$","strong",null,{"children":"competent person"}]," and ",["$","strong",null,{"children":"qualified person"}],". These are not interchangeable. Each has a specific definition, specific authority, and specific limitations. Getting this wrong doesn't just mean paperwork problems — it means your inspections may not count at all."]}],["$","h2",null,{"children":"The OSHA Definitions"}],["$","h3",null,{"children":"Competent Person (29 CFR 1926.1401)"}],["$","blockquote",null,{"children":["$","p",null,{"children":"One who is capable of identifying existing and predictable hazards in the surroundings or working conditions which are unsanitary, hazardous, or dangerous to employees, and who has authorization to take prompt corrective measures to eliminate them."}]}],"$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b"]}]}],"$L2c"]}],"$L2d"],["$L2e"],"$L2f"]}]
7:["$","$1","h",{"children":[null,["$","$L30",null,{"children":"$L31"}],["$","div",null,{"hidden":true,"children":["$","$L32",null,{"children":["$","$33",null,{"name":"Next.Metadata","children":"$L34"}]}]}],["$","meta",null,{"name":"next-size-adjust","content":""}]]}]
35:I[85437,["/_next/static/chunks/c227801be8230225.js"],"Image"]
38:I[97367,["/_next/static/chunks/ff1a16fafef87110.js","/_next/static/chunks/d2be314c3ece3fbe.js"],"OutletBoundary"]
d:["$","p",null,{"children":["Key elements: (1) can identify hazards, and (2) has the ",["$","strong",null,{"children":"authority"}]," to take corrective action. A competent person isn't just knowledgeable — they must have organizational authority to shut things down when something is unsafe."]}]
e:["$","h3",null,{"children":"Qualified Person (29 CFR 1926.1401)"}]
f:["$","blockquote",null,{"children":["$","p",null,{"children":"A person who, by possession of a recognized degree, certificate, or professional standing, or who by extensive knowledge, training, and experience, successfully demonstrated the ability to solve/resolve problems relating to the subject matter, the work, or the project."}]}]
10:["$","p",null,{"children":["Key elements: Requires ",["$","strong",null,{"children":"demonstrated expertise"}]," through formal credentials or extensive verifiable experience. This is a higher technical bar than \"competent person.\""]}]
11:["$","h2",null,{"children":"Who Can Do What: The Breakdown"}]
12:["$","h3",null,{"children":"What a Competent Person Can Do"}]
13:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Shift inspections:"}]," Pre-shift visual checks per 1926.1412(a)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Ground condition assessments:"}]," Determine if ground can support the crane (1926.1402)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Assembly/disassembly oversight:"}]," Direct A/D operations (1926.1404)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hazard assessment:"}]," Evaluate site conditions, power line proximity, load path"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Tag/lock-out decisions:"}]," Take equipment out of service when hazards are identified"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Monthly periodic inspections:"}]," Routine periodic inspections per 1926.1412(b)"]}]]}]
14:["$","h3",null,{"children":"What Only a Qualified Person Can Do"}]
15:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Annual comprehensive inspections:"}]," Required by 1926.1412(c) — must be performed by a qualified person"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Determine inspection intervals:"}]," Set the periodic inspection schedule based on usage, conditions, and manufacturer requirements"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Wire rope assessments:"}]," Evaluate wire rope condition against removal criteria under 1926.1413"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Structural evaluations:"}]," Assess cracks, deformation, corrosion, and structural integrity"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Modifications and repairs:"}]," Approve design changes, modifications, or structural repairs to crane components"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Load testing:"}]," Design and supervise load tests when required"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Crane rating changes:"}]," Evaluate and authorize capacity changes"]}]]}]
16:["$","h2",null,{"children":"The Most Common Mistakes"}]
17:["$","h3",null,{"children":"1. Using an Operator for Annual Inspections"}]
18:["$","p",null,{"children":"Your best operator may have 30 years of experience and know the crane inside and out. That's great — and it doesn't automatically make them a \"qualified person\" for annual inspection purposes. Unless they have formal credentials (engineering degree, manufacturer certification, NCCCO inspector cert) or you can document extensive specific training and experience that meets the OSHA definition, their annual inspection is vulnerable to challenge."}]
19:["$","h3",null,{"children":"2. No Documentation of Qualifications"}]
1a:["$","p",null,{"children":"Even if someone genuinely meets the \"qualified person\" definition, you need to be able to prove it. When OSHA asks \"Who performed this annual inspection and what are their qualifications?\" — \"Oh, that's Mike, he's been doing this for 20 years\" is not a compliant answer. You need their credentials, training records, certifications, and experience documentation on file."}]
1b:["$","h3",null,{"children":"3. Competent Person Without Authority"}]
1c:["$","p",null,{"children":"The definition requires authorization to take prompt corrective action. If your designated competent person can identify a hazard but needs to call their supervisor for permission to shut down the crane, they don't meet the definition. The authority to act must be real, documented, and understood by everyone on site."}]
1d:["$","h3",null,{"children":"4. Single Person for Everything"}]
1e:["$","p",null,{"children":"Having one person serve as both competent and qualified person isn't prohibited — if they genuinely meet both definitions. But it creates a single point of failure. When that person is sick, on vacation, or leaves the company, your entire inspection program stalls. Build depth."}]
1f:["$","h3",null,{"children":"5. Assuming Third-Party Inspectors Cover Everything"}]
20:["$","p",null,{"children":"Hiring a third-party qualified person for annual inspections is common and smart. But it doesn't relieve you of the obligation to have competent persons on site for daily and periodic inspections. The third party handles annuals — you still need internal people handling everything else."}]
21:["$","h2",null,{"children":"How to Designate and Document"}]
22:["$","h3",null,{"children":"For Competent Persons"}]
23:["$","ol",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Formally designate in writing."}]," A signed letter or designation form that identifies the person by name, states they are designated as a competent person, and specifies the scope of their authority."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Document their training."}]," Crane-specific safety training, hazard recognition, OSHA standards familiarization. Keep certificates and training records."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Confirm authority."}]," The designation must explicitly grant authority to take corrective action, including stopping operations and removing equipment from service."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Review periodically."}]," Competent person designations should be reviewed annually or when responsibilities change."]}]]}]
24:["$","h3",null,{"children":"For Qualified Persons"}]
25:["$","ol",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Verify credentials."}]," Collect and maintain copies of degrees, certifications (NCCCO, manufacturer certs), professional licenses, or detailed experience documentation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Match qualifications to equipment."}]," A person qualified to inspect overhead bridge cranes may not be qualified for mobile hydraulic cranes. Ensure the qualifier matches the equipment."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Maintain current records."}]," Certifications expire. Training becomes outdated. Review qualified person files annually."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Document alongside inspections."}]," Every annual inspection record should include the inspector's qualifications — not just their name."]}]]}]
26:["$","h2",null,{"children":"What OSHA Looks for During an Audit"}]
27:["$","p",null,{"children":"When an OSHA compliance officer reviews your crane program, they will:"}]
28:["$","ul",null,{"children":[["$","li",null,{"children":"Ask who performs each type of inspection"}],["$","li",null,{"children":"Request documentation of those persons' qualifications or designations"}],["$","li",null,{"children":"Verify that competent persons have documented authority to take corrective action"}],["$","li",null,{"children":"Check that qualified persons meet the definition for the specific inspection type they performed"}],["$","li",null,{"children":"Look for gaps where the wrong designation level performed an inspection that required a higher one"}]]}]
29:["$","p",null,{"children":"If they find an annual inspection signed by someone who doesn't meet the \"qualified person\" standard, that inspection doesn't count. And now you're not just cited for the personnel issue — you're cited for not having a valid annual inspection at all."}]
2a:["$","h2",null,{"children":"Get It Right From the Start"}]
2b:["$","p",null,{"children":"The competent/qualified distinction isn't bureaucratic hairsplitting. It's the foundation your entire crane inspection program stands on. Get the designations right, document everything, and make sure every inspection is signed by someone with the proper authority and qualifications for that inspection type."}]
