0:{"buildId":"GExPKXDp67qBPcTo087Bg","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"29 CFR 1926.1412 Explained: Pre-Shift Crane Inspection Rules\",\"description\":\"A plain-English breakdown of 29 CFR 1926.1412 — the OSHA standard governing crane inspections on construction sites. Learn what each subsection requires, who is responsible, and how to stay compliant.\",\"datePublished\":\"2026-02-01\",\"dateModified\":\"2026-02-01\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/29-cfr-1926-1412-explained\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"29 CFR 1926.1412 Explained: Pre-Shift Crane Inspection Rules\",\"item\":\"https://cranecheck.com/blog/29-cfr-1926-1412-explained\"}]}"}}],["$","$L2",null,{}],["$","$L3",null,{}],["$","main",null,{"id":"main-content","children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-4xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Regulations"}],["$","span",null,{"className":"text-xs text-gray-400","children":"February 1, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"13 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold text-white mb-4 leading-tight","children":"29 CFR 1926.1412 Explained: Pre-Shift Crane Inspection Rules"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-3xl","children":"A plain-English breakdown of the OSHA standard that governs crane inspections on construction sites — what it requires, who is responsible, and how to comply."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand hover:prose-a:text-brand-dark prose-a:no-underline hover:prose-a:underline","children":[["$","div",null,{"className":"not-prose","children":["$","$L4",null,{}]}],["$","p",null,{"children":["If you operate, own, or manage cranes on a construction site in the United States, one regulation matters more than almost any other:"," ",["$","strong",null,{"children":"29 CFR 1926.1412"}],". This is the OSHA standard that spells out exactly what crane inspections are required, how often they must happen, who must perform them, and what documentation you need to keep on file."]}],["$","p",null,{"children":"Violating 1926.1412 can result in OSHA citations, significant fines, project shutdowns, and — most importantly — serious injuries or fatalities. Yet many contractors and crane operators still struggle with the specifics because the regulation is dense, cross-references other standards, and uses terminology that is easy to confuse."}],["$","p",null,{"children":["This guide breaks down every major subsection of 29 CFR 1926.1412 in plain English, explains who is responsible for each requirement, and shows you how to build a compliance system that holds up under an OSHA audit. For a broader look at all OSHA crane inspection obligations, see our"," ","$L5","."]}],"$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41"]}]}],"$L42","$L43"]}],"$L44"],["$L45","$L46"],"$L47"]}],"loading":null,"isPartial":false}
5:["$","$L48",null,{"href":"/blog/osha-crane-inspection-requirements","children":"complete guide to OSHA crane inspection requirements"}]
6:["$","h2",null,{"children":"What Is 29 CFR 1926.1412?"}]
7:["$","p",null,{"children":["Title 29 of the Code of Federal Regulations, Part 1926, Subpart CC covers cranes and derricks in construction. Section 1926.1412 specifically addresses ",["$","strong",null,{"children":"inspections"}]," — the recurring checks that must be performed on cranes before they are used on a job site."]}]
8:["$","p",null,{"children":"The standard applies to all cranes and derricks used in construction, including mobile cranes (lattice boom crawlers, hydraulic truck cranes, rough-terrain cranes), tower cranes, overhead and gantry cranes used in construction activities, and derricks. It does not apply to general industry cranes governed by 29 CFR 1910.179, though many of the inspection principles overlap."}]
9:["$","p",null,{"children":"Practically speaking, if your crane is on a construction site and falls under Subpart CC, 1926.1412 is the inspection standard you must follow."}]
a:["$","h2",null,{"children":"Who Does It Apply To?"}]
b:["$","p",null,{"children":["The regulation places obligations on multiple parties. The"," ",["$","strong",null,{"children":"controlling entity"}]," (typically the general contractor) must ensure inspections are performed. The"," ",["$","strong",null,{"children":"crane owner"}]," is responsible for making the crane available with current documentation. And the"," ",["$","strong",null,{"children":"crane operator"}]," is responsible for performing shift-level visual inspections and refusing to operate equipment that has deficiencies affecting safe operation."]}]
c:["$","p",null,{"children":"Understanding these overlapping duties is critical. OSHA can cite multiple parties for the same violation if inspections are missed."}]
d:["$","h2",null,{"children":"Subsection (d): Each-Shift Inspection"}]
e:["$","p",null,{"children":["Subsection (d) is where most day-to-day compliance lives. It requires a visual inspection ",["$","strong",null,{"children":"before each shift"}]," ","that the crane is used. The person performing this inspection must be a ",["$","em",null,{"children":"competent person"}]," — typically the crane operator."]}]
f:["$","h3",null,{"children":"What Must Be Checked"}]
10:["$","p",null,{"children":"The each-shift inspection covers items that could become hazardous between shifts or during transport. OSHA requires the competent person to visually inspect the following before the crane is used:"}]
11:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Control mechanisms"}]," — all controls must be tested for proper operation and labeled correctly"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Safety devices and operational aids"}]," — anti-two-block devices, boom angle indicators, load moment indicators, and similar devices must be functioning"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Wire rope"}]," — checked for visible damage, kinking, bird-caging, corrosion, or broken wires that meet removal-from-service criteria"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hydraulic, pneumatic, and other pressurized lines"}]," ","— inspected for leaks, damage, or deterioration"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hooks and latches"}]," — checked for deformation, cracks, excessive wear, and latch operation"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Electrical apparatus"}]," — inspected for malfunctioning components, damage to insulation, or exposed wiring"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Tires (for rubber-tired equipment)"}]," — checked for proper inflation and condition"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Ground conditions"}]," — the area must support the crane, and outriggers or stabilizers must be properly deployed"]}]]}]
12:["$","p",null,{"children":["If a deficiency is identified that constitutes a safety hazard, the crane must be taken out of service until the issue is corrected. The operator must not begin work until the inspection is complete. For a ready-to-use version of this list, see our"," ",["$","$L48",null,{"href":"/blog/daily-crane-inspection-checklist","children":"daily crane inspection checklist"}],"."]}]
13:["$","h3",null,{"children":"Documentation for Shift Inspections"}]
14:["$","p",null,{"children":["OSHA does not explicitly require written documentation for each-shift inspections under subsection (d). However, there is a critical caveat: if a deficiency is found, you ",["$","em",null,{"children":"must"}]," ","document it. And from a practical standpoint, keeping a record of every shift inspection is the only way to prove compliance during an audit. An inspector who sees no records will assume no inspections were performed."]}]
15:["$","h2",null,{"children":"Subsection (e): Monthly Inspection"}]
16:["$","p",null,{"children":["Subsection (e) requires a more thorough inspection at least once per month. This inspection must be performed by a"," ",["$","strong",null,{"children":"competent person"}]," and goes beyond the visual checks of a shift inspection."]}]
17:["$","h3",null,{"children":"Scope of Monthly Inspections"}]
18:["$","p",null,{"children":"Monthly inspections cover everything in the shift inspection plus additional items that are less likely to change day-to-day but can deteriorate over weeks:"}]
19:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Structural members"}]," — boom sections, jib, turntable, and frame checked for cracks, deformation, or corrosion"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Fasteners"}]," — bolts, pins, and keepers inspected for looseness or missing components"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Guards and covers"}]," — all guards on moving parts must be in place and functional"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Sheaves and drums"}]," — inspected for wear, cracks, and proper rope tracking"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Braking systems"}]," — tested for proper engagement and holding capacity"]}]]}]
1a:["$","h3",null,{"children":"Documentation Requirements"}]
1b:["$","p",null,{"children":["Unlike shift inspections, monthly inspections"," ",["$","strong",null,{"children":"must be documented"}],". The documentation must include the items inspected, the results of the inspection, and the name and signature of the person who performed it. These records must be retained for a minimum of ",["$","strong",null,{"children":"three months"}],"."]}]
1c:["$","h2",null,{"children":"Subsection (f): Annual/Comprehensive Inspection"}]
1d:["$","p",null,{"children":["Subsection (f) mandates a comprehensive inspection at least once every ",["$","strong",null,{"children":"12 months"}],". This is the most rigorous inspection tier and must be performed by a"," ",["$","strong",null,{"children":"qualified person"}]," — a higher standard than the competent person required for shift and monthly inspections."]}]
1e:["$","h3",null,{"children":"What the Annual Inspection Covers"}]
1f:["$","p",null,{"children":"The annual inspection encompasses all items from shift and monthly inspections and adds a thorough examination of:"}]
20:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Structural integrity"}]," — detailed inspection of all structural components, including welds, for cracks, fatigue, or deformation"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Wire rope replacement criteria"}]," — a detailed assessment per manufacturer specifications and applicable standards"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hydraulic and pneumatic systems"}]," — full system check including cylinders, valves, fittings, and relief settings"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Electrical systems"}]," — complete evaluation of wiring, connections, contactors, and limit switches"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Safety devices"}]," — full functional testing of all safety devices and operational aids"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Manufacturer-specific items"}]," — any additional checks specified by the crane manufacturer"]}]]}]
21:["$","h3",null,{"children":"Certification and Record Retention"}]
22:["$","p",null,{"children":["The annual inspection must result in a written certification record. This record must include the date of the inspection, the signature of the qualified person who performed it, and the serial number or other identifier of the equipment inspected. Annual inspection records must be retained until the next annual inspection is completed — effectively a rolling"," ",["$","strong",null,{"children":"12-month retention window"}],"."]}]
23:["$","p",null,{"children":"The crane must not be used unless a current annual inspection certification is available. If the annual inspection is overdue, the crane is out of compliance and should not operate until the inspection is completed."}]
24:["$","h2",null,{"children":"Subsection (g): Severe Service"}]
25:["$","p",null,{"children":["Subsection (g) addresses cranes operating under"," ",["$","strong",null,{"children":"severe service conditions"}]," — environments or usage patterns that accelerate wear and increase the likelihood of failure. Examples include:"]}]
26:["$","ul",null,{"children":[["$","li",null,{"children":"Corrosive environments (chemical plants, coastal sites)"}],["$","li",null,{"children":"Extreme temperatures (steel mills, arctic conditions)"}],["$","li",null,{"children":"High cycle rates or continuous heavy lifts"}],["$","li",null,{"children":"Exposure to hazardous materials or abrasive dust"}]]}]
27:["$","p",null,{"children":["When a crane operates under severe service conditions, OSHA requires ",["$","strong",null,{"children":"more frequent inspections"}]," than the standard shift/monthly/annual schedule. The frequency must be determined by a qualified person based on the specific conditions and the manufacturer's recommendations. This often means daily or weekly inspections that are closer in scope to monthly inspections, and semi-annual comprehensive inspections instead of annual ones."]}]
28:["$","h2",null,{"children":"Competent Person vs. Qualified Person"}]
29:["$","p",null,{"children":"These two terms appear throughout 1926.1412 and are frequently confused. OSHA defines them differently, and the distinction matters for compliance:"}]
2a:["$","h3",null,{"children":"Competent Person"}]
2b:["$","p",null,{"children":["A ",["$","strong",null,{"children":"competent person"}]," is someone who can identify existing and predictable hazards in the surroundings or working conditions and has the authorization to take prompt corrective measures to eliminate them. For crane inspections, this is typically an experienced crane operator or a dedicated safety professional. Competent persons perform shift and monthly inspections."]}]
2c:["$","h3",null,{"children":"Qualified Person"}]
2d:["$","p",null,{"children":["A ",["$","strong",null,{"children":"qualified person"}]," has a recognized degree, certificate, or professional standing, ",["$","em",null,{"children":"or"}]," has extensive knowledge, training, and experience, and can solve problems related to the subject matter. For crane inspections, qualified persons are typically certified crane inspectors, professional engineers, or highly experienced mechanics with documented training. Qualified persons perform annual inspections and determine severe-service inspection intervals."]}]
2e:["$","p",null,{"children":"The key difference: a competent person can identify hazards, while a qualified person can analyze the equipment at an engineering level. Using a competent person where a qualified person is required is a citable violation."}]
2f:["$","h2",null,{"children":"Documentation and Record-Keeping Requirements"}]
30:["$","p",null,{"children":"Record-keeping is where many organizations fail during OSHA audits. Here is a summary of the documentation requirements across all subsections:"}]
31:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Shift inspections (d)"}]," — Not strictly required to be documented, but deficiencies must be recorded. In practice, you should document every shift inspection to demonstrate compliance."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Monthly inspections (e)"}]," — Must be documented with items checked, results, inspector name and signature. Retained for a minimum of three months."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Annual inspections (f)"}]," — Must produce a written certification record with date, qualified person signature, and equipment identifier. Retained until the next annual inspection."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Severe service (g)"}]," — Follows the documentation rules for whichever inspection tier applies, with frequency adjustments documented by the qualified person."]}]]}]
32:["$","p",null,{"children":["Records must be available for review at the job site or readily accessible. During an OSHA inspection, the compliance officer will ask to see these documents. If they are missing, incomplete, or disorganized, expect a citation. For a deeper look at audit preparation, read our guide on"," ",["$","$L48",null,{"href":"/blog/osha-crane-audit-preparation","children":"how to prepare for an OSHA crane audit"}],"."]}]
33:["$","h2",null,{"children":"How Long Must Records Be Retained?"}]
34:["$","p",null,{"children":"The retention periods specified in 1926.1412 are minimums. Many organizations choose to retain records longer for liability and insurance purposes:"}]
35:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Shift inspection records"}]," — No mandated retention period, but best practice is to keep them for at least three months"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Monthly inspection records"}]," — Minimum of three months"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Annual inspection certification"}]," — Until the next annual inspection is completed (approximately 12 months)"]}]]}]
36:["$","p",null,{"children":["Industry best practice is to retain all inspection records for a minimum of ",["$","strong",null,{"children":"five years"}],". This protects you in litigation, helps demonstrate a pattern of compliance, and satisfies insurance carrier requirements, which often exceed OSHA minimums."]}]
37:["$","h2",null,{"children":"Penalties for Non-Compliance"}]
38:["$","p",null,{"children":"OSHA penalties for crane inspection violations have increased substantially in recent years. As of 2026, the penalty structure is:"}]
39:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Other-Than-Serious violation"}]," — Up to $16,550 per violation"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Serious violation"}]," — Up to $16,550 per violation"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Willful or Repeat violation"}]," — Up to $165,514 per violation"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Failure to Abate"}]," — Up to $16,550 per day beyond the abatement date"]}]]}]
3a:["$","p",null,{"children":"Missing or incomplete inspection records are among the most common crane-related citations. These are often classified as serious violations because inadequate inspections directly increase the risk of a catastrophic failure. Multiple missing records can result in multiple citations — one per crane, per missed inspection period."}]
3b:["$","h2",null,{"children":"How CraneCheck Maps to Each Subsection"}]
3c:["$","p",null,{"children":"CraneCheck was built specifically to help crane operators, mechanics, and safety managers comply with every tier of 29 CFR 1926.1412. Here is how the platform maps to each requirement:"}]
3d:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Shift inspections (d)"}]," — CraneCheck provides pre-built digital checklists that match OSHA's shift inspection requirements. Operators complete inspections on a phone or tablet, and every record is timestamped, geotagged, and stored automatically."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Monthly inspections (e)"}]," — The monthly inspection template includes all required items, captures the inspector's digital signature, and generates a compliant record that is retained indefinitely (well beyond the three-month minimum)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Annual inspections (f)"}]," — CraneCheck tracks annual inspection due dates per crane, sends reminders before certifications expire, and stores the certification record with the qualified person's signature and equipment serial number."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Severe service (g)"}]," — Custom inspection schedules can be configured per crane to match the frequency determined by your qualified person. CraneCheck enforces the schedule and flags overdue inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Record retention"}]," — All records are stored in the cloud with unlimited retention. You never have to worry about lost paperwork, illegible entries, or records that were thrown away too early."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Audit readiness"}]," — CraneCheck generates an exportable compliance report for any crane, any date range, on demand. When OSHA shows up, you pull the report in seconds — not hours."]}]]}]
3e:["$","p",null,{"children":["Moving from paper logs to a digital system is one of the highest-impact changes you can make for crane inspection compliance. For a detailed comparison, see our breakdown of"," ",["$","$L48",null,{"href":"/blog/crane-inspection-software-vs-paper","children":"crane inspection software vs paper logs"}],"."]}]
3f:["$","h2",null,{"children":"Key Takeaways"}]
40:["$","p",null,{"children":"29 CFR 1926.1412 is not optional, and it is not ambiguous. Every crane on a construction site must receive shift, monthly, and annual inspections performed by appropriately qualified personnel, with proper documentation retained for the required periods. The penalties for non-compliance are steep, and the safety consequences of skipping inspections can be catastrophic."}]
41:["$","p",null,{"children":"The most common compliance failures are not dramatic — they are organizational. A shift inspection that was done but not recorded. A monthly inspection form that cannot be found. An annual certification that expired two weeks ago because nobody tracked the date. These are the gaps that result in OSHA citations, and they are entirely preventable with the right system in place."}]
