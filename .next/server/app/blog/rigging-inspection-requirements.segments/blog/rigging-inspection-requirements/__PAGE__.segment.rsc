0:{"buildId":"f-wLp3UizMU5tGDgsHayP","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Rigging Inspection Requirements: Slings, Shackles, and Hardware\",\"description\":\"Complete OSHA rigging inspection requirements under 29 CFR 1926.251. Covers sling inspection criteria, shackle load ratings, removal-from-service standards, and documentation best practices for crane rigging hardware.\",\"datePublished\":\"2026-03-08\",\"dateModified\":\"2026-03-08\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/rigging-inspection-requirements\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Rigging Inspection Requirements: Slings, Shackles, and Hardware\",\"item\":\"https://cranecheck.com/blog/rigging-inspection-requirements\"}]}"}}],["$","$L2",null,{}],["$","$L3",null,{}],["$","main",null,{"id":"main-content","children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Rigging"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 8, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"11 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"Rigging Inspection Requirements: Slings, Shackles, and Hardware"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl","children":"Your crane might pass every inspection, but if the rigging fails, none of that matters. OSHA 1926.251 and ASME B30.9 set strict requirements for sling and rigging hardware inspections. Here is what they require."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-strong:text-navy","children":[["$","div",null,{"className":"not-prose","children":["$","$L4",null,{}]}],["$","p",null,{"children":"Rigging failures account for a disproportionate share of crane-related injuries and fatalities. A 2023 OSHA analysis of crane incident reports found that rigging and load handling issues were involved in over 35% of crane accidents — more than mechanical failure, structural collapse, or operator error. The rigging is the link between the crane and the load. If it fails, everything fails."}],["$","p",null,{"children":"Yet rigging inspection is often treated as an afterthought. Operators check the crane itself meticulously but grab whatever sling is closest without inspecting it. This guide covers the federal requirements for rigging inspection, what to look for on each type of sling and hardware, and when equipment must be removed from service."}],["$","h2",null,{"children":"OSHA 1926.251: The Federal Standard"}],"$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21"]}]}],"$L22","$L23"]}],"$L24"],["$L25","$L26"],"$L27"]}],"loading":null,"isPartial":false}
5:["$","p",null,{"children":[["$","strong",null,{"children":"29 CFR 1926.251"}]," governs rigging equipment for material handling in construction. It covers:"]}]
6:["$","ul",null,{"children":[["$","li",null,{"children":"Wire rope slings (1926.251(c))"}],["$","li",null,{"children":"Natural and synthetic fiber rope slings (1926.251(d))"}],["$","li",null,{"children":"Synthetic web slings (1926.251(e))"}],["$","li",null,{"children":"Chain slings (1926.251(f))"}],["$","li",null,{"children":"Shackles and hardware (1926.251(b))"}]]}]
7:["$","p",null,{"children":["The overarching requirement in 1926.251(a)(1) is simple: ",["$","strong",null,{"children":"rigging equipment shall be inspected prior to use on each shift and as necessary during its use to ensure that it is safe."}]," Defective rigging must be immediately removed from service."]}]
8:["$","h2",null,{"children":"Pre-Use Inspection: Every Shift, Every Sling"}]
9:["$","p",null,{"children":"Before using any sling or rigging hardware, a competent person must perform a visual inspection. This is not a suggestion — it is a federal requirement that applies to every shift. Here is what to inspect for each type:"}]
a:["$","h3",null,{"children":"Wire Rope Slings"}]
b:["$","ul",null,{"children":[["$","li",null,{"children":"Broken wires — 10 randomly distributed in one rope lay, or 5 in one strand in one lay = remove from service"}],["$","li",null,{"children":"Severe corrosion, pitting, or rust that reduces wire diameter"}],["$","li",null,{"children":"Kinking, crushing, bird-caging, or other distortion of the rope structure"}],["$","li",null,{"children":"End fittings — cracked, deformed, or worn sockets, thimbles, splices"}],["$","li",null,{"children":"Heat damage — discoloration from welding, torch cutting, or electrical contact"}],["$","li",null,{"children":"Core protrusion or separation"}],["$","li",null,{"children":"Reduction in rope diameter exceeding 5% (measured at the smallest point)"}]]}]
c:["$","h3",null,{"children":"Synthetic Web Slings"}]
d:["$","ul",null,{"children":[["$","li",null,{"children":"Acid or caustic burns — any visible damage from chemical exposure"}],["$","li",null,{"children":"Melting or charring of any part of the sling surface"}],["$","li",null,{"children":"Snags, punctures, tears, or cuts"}],["$","li",null,{"children":"Broken or worn stitching in load-bearing splices"}],["$","li",null,{"children":"Knots in any part of the sling"}],["$","li",null,{"children":"Excessive abrasive wear — exposed core yarns"}],["$","li",null,{"children":"Fittings — distorted, cracked, or pitted hooks, rings, links, or end attachments"}],["$","li",null,{"children":[["$","strong",null,{"children":"Missing or illegible sling identification tag"}]," — if you cannot read the rated capacity, the sling must not be used"]}]]}]
e:["$","h3",null,{"children":"Chain Slings"}]
f:["$","ul",null,{"children":[["$","li",null,{"children":"Stretch — any chain link stretched beyond 5% of its original length = immediate removal"}],["$","li",null,{"children":"Wear — link cross-section reduced by more than 10% at any point"}],["$","li",null,{"children":"Nicks, gouges, or cracks in any link"}],["$","li",null,{"children":"Bent or twisted links"}],["$","li",null,{"children":"Heat damage — any evidence of exposure to temperatures above manufacturer limits"}],["$","li",null,{"children":"Weld splatter — indicates unauthorized field repair"}]]}]
10:["$","h3",null,{"children":"Shackles and Hardware"}]
11:["$","ul",null,{"children":[["$","li",null,{"children":"Deformation — any visible bending or distortion of the bow or pin"}],["$","li",null,{"children":"Cracks — use dye penetrant or magnetic particle testing if suspected"}],["$","li",null,{"children":"Corrosion or pitting that reduces cross-section"}],["$","li",null,{"children":"Pin wear — excessive play between pin and bow"}],["$","li",null,{"children":"Thread damage on screw-pin shackles"}],["$","li",null,{"children":"Missing or illegible rated load markings"}],["$","li",null,{"children":"Unauthorized modifications — welding, drilling, grinding"}]]}]
12:["$","h2",null,{"children":"Periodic (Thorough) Inspections"}]
13:["$","p",null,{"children":"Beyond pre-use visual inspections, ASME B30.9 requires periodic thorough inspections at intervals based on:"}]
14:["$","ul",null,{"children":[["$","li",null,{"children":"Frequency of use"}],["$","li",null,{"children":"Severity of service conditions"}],["$","li",null,{"children":"Nature of lifts being made"}],["$","li",null,{"children":"Experience gained on the service life of slings used in similar circumstances"}]]}]
15:["$","p",null,{"children":"For slings in regular daily use, periodic inspections should be conducted at least annually. For severe service (high frequency, near-capacity loads, corrosive environments), quarterly periodic inspections are recommended."}]
16:["$","p",null,{"children":"Periodic inspections must be documented. Records should include: sling identification number, date, inspector name and qualifications, items inspected, condition, and disposition (returned to service, repaired, or removed from service)."}]
17:["$","h2",null,{"children":"Removal from Service Criteria"}]
18:["$","p",null,{"children":["OSHA and ASME are clear: defective rigging must be ",["$","strong",null,{"children":"immediately removed from service"}],". There is no \"use it one more time\" exception. Specific removal criteria by type:"]}]
19:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Wire rope slings:"}]," 10+ broken wires per lay, 5% diameter reduction, kinking, core protrusion, heat damage, end fitting damage"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Web slings:"}]," acid burns, melting, snags exposing core, worn stitching, missing capacity tag, knots"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Chain slings:"}]," 5% stretch, 10% wear, cracks, gouges, heat damage, unauthorized repairs"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Shackles:"}]," any visible deformation, cracks, excessive pin wear, missing load rating"]}]]}]
1a:["$","p",null,{"children":"Removed equipment should be physically tagged \"DO NOT USE\" and segregated until it is either repaired by the manufacturer (or a qualified person) and re-certified, or destroyed. Cutting web slings and bending hooks open are common destruction methods that prevent re-use."}]
1b:["$","h2",null,{"children":"Documentation That Protects You"}]
1c:["$","p",null,{"children":"Rigging inspection records serve two purposes: regulatory compliance and legal defense. If a rigging failure causes an injury, the first question will be: \"When was this equipment last inspected, and by whom?\""}]
1d:["$","p",null,{"children":"Your documentation system should track:"}]
1e:["$","ul",null,{"children":[["$","li",null,{"children":"Every sling and piece of rigging hardware by unique ID"}],["$","li",null,{"children":"Pre-use inspection completion (date, inspector, pass/fail)"}],["$","li",null,{"children":"Periodic inspection results with detailed findings"}],["$","li",null,{"children":"Removal from service records (reason, date, disposition)"}],["$","li",null,{"children":"Photos of deficiencies found during inspection"}],["$","li",null,{"children":"Corrective actions taken and verified"}]]}]
1f:["$","p",null,{"children":["Managing this on paper across a fleet of hundreds of slings is impractical. ",["$","$L28",null,{"href":"/pricing","children":"CraneCheck"}]," tracks rigging equipment alongside your crane fleet — same inspection workflow, same photo documentation, same audit trail. Every sling has a history. Every inspection is recorded. Every deficiency is tracked to resolution."]}]
20:["$","h2",null,{"children":"Key Takeaways"}]
21:["$","ul",null,{"children":[["$","li",null,{"children":"OSHA 1926.251 requires rigging inspection before every shift — this is not optional"}],["$","li",null,{"children":"Each sling type (wire rope, web, chain) has specific removal-from-service criteria — know them"}],["$","li",null,{"children":"Shackles and hardware must be inspected for deformation, cracks, and legible load ratings"}],["$","li",null,{"children":"Periodic thorough inspections must be documented with inspector qualifications"}],["$","li",null,{"children":"Defective rigging must be immediately removed — no exceptions, no \"one more lift\""}],["$","li",null,{"children":"Digital tracking of rigging equipment is the only practical way to maintain compliance at scale"}]]}]
