f:["$","li",null,{"children":[["$","strong",null,{"children":"Replaced load-sustaining parts"}]," must be at least equivalent to the original in terms of material, dimension, and strength"]}]
10:["$","h2",null,{"children":"What Should Be in Your Maintenance Log"}]
11:["$","p",null,{"children":"While OSHA doesn't prescribe an exact format for maintenance records, enforcement practice and industry standards (ANSI B30, ASME) establish clear expectations. A defensible maintenance log should include:"}]
12:["$","h3",null,{"children":"For Each Maintenance Activity"}]
13:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Date and time"}]," of the maintenance"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Equipment identification"}]," — serial number, unit number, or other unique identifier"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Description of work performed"}]," — specific, not \"general maintenance\""]}],["$","li",null,{"children":[["$","strong",null,{"children":"Parts replaced"}]," — part numbers, specifications, and source"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Who performed the work"}]," — name and qualifications"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hours/usage at time of maintenance"}]," — connects to interval-based schedules"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Next scheduled maintenance"}]," — based on manufacturer intervals or qualified person determination"]}]]}]
14:["$","h3",null,{"children":"For Preventive Maintenance Programs"}]
15:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"PM schedule"}]," — what gets done at what intervals (daily, weekly, monthly, quarterly, annual)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Manufacturer service bulletins"}]," — tracked and implemented"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Fluid analysis records"}]," — hydraulic fluid, gear oil, engine oil sampling and results"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lubrication records"}]," — what was greased, when, with what product"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Filter change records"}]," — hydraulic, fuel, air, with hour/date tracking"]}]]}]
16:["$","h3",null,{"children":"For Corrective Maintenance (Repairs)"}]
17:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"What failed and how it was discovered"}]," — inspection finding, operator report, breakdown"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Root cause"}]," — if determined"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Repair details"}]," — specific work done, including welding procedures if applicable"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Return-to-service verification"}]," — who authorized the crane to go back to work and on what basis"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Testing performed"}]," — load tests, function tests, safety device verification after repair"]}]]}]
18:["$","h2",null,{"children":"Manufacturer Requirements: Not Optional"}]
19:["$","p",null,{"children":"OSHA 1926.1417(a) requires compliance with manufacturer maintenance procedures. This is not \"best practice\" — it's a legal requirement. That means:"}]
1a:["$","ul",null,{"children":[["$","li",null,{"children":["You must ",["$","strong",null,{"children":"have"}]," the manufacturer's maintenance manual for every crane you operate"]}],["$","li",null,{"children":["You must ",["$","strong",null,{"children":"follow"}]," the intervals and procedures specified in that manual"]}],["$","li",null,{"children":["You must ",["$","strong",null,{"children":"document"}]," that you followed them"]}],["$","li",null,{"children":["If you deviate from manufacturer procedures, you need a ",["$","strong",null,{"children":"qualified person"}]," to determine and document alternative procedures that are at least as protective"]}]]}]
1b:["$","p",null,{"children":"During an OSHA investigation, the compliance officer will request the manufacturer's manual and compare your maintenance records against the manufacturer's required intervals. Gaps between what the manufacturer requires and what you actually did are citations waiting to happen."}]
1c:["$","h2",null,{"children":"How Long to Keep Records"}]
1d:["$","p",null,{"children":"OSHA's crane standards don't specify an explicit retention period for all maintenance records, but practical and legal requirements establish clear guidance:"}]
1e:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Inspection records:"}]," Must be maintained until the next inspection of that type is completed (minimum)"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Annual inspection records:"}]," Maintain for the life of the equipment — these establish the crane's ongoing safety history"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Maintenance records:"}]," Industry standard is life of the equipment or a minimum of 5 years, whichever is longer"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Modification/repair records:"}]," Permanently — these affect the crane's rated capacity and operational parameters"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Litigation hold:"}]," If there is any incident, investigation, or litigation, all records must be preserved indefinitely until the matter is resolved"]}]]}]
1f:["$","p",null,{"children":[["$","strong",null,{"children":"Our recommendation:"}]," Keep everything for the life of the equipment plus 5 years after disposal. Storage is cheap. Legal exposure from missing records is not."]}]
20:["$","h2",null,{"children":"Common Citation Triggers"}]
21:["$","h3",null,{"children":"1. No Documented Maintenance Program"}]
22:["$","p",null,{"children":"\"We maintain our cranes when they need it\" is not a maintenance program. OSHA expects a written, systematic program established by a qualified person that covers all equipment in your fleet."}]
23:["$","h3",null,{"children":"2. Manufacturer Interval Gaps"}]
24:["$","p",null,{"children":"The manufacturer says hydraulic fluid change every 2,000 hours. Your records show 4,000 hours between changes — or no records at all. This is a direct violation of 1926.1417(a)."}]
25:["$","h3",null,{"children":"3. Unqualified Repairs"}]
26:["$","p",null,{"children":"Structural repairs, welding on load-bearing members, or modifications performed by unqualified persons or without proper procedures. Under 1926.1417(e), these require qualified person oversight and potentially engineering approval."}]
27:["$","h3",null,{"children":"4. Non-OEM Parts Without Documentation"}]
28:["$","p",null,{"children":"Using aftermarket parts is allowed — but they must be equivalent to OEM specs. Without documentation proving equivalence, you're exposed. Keep specs, certifications, and material test reports for critical replacement parts."}]
29:["$","h3",null,{"children":"5. No Return-to-Service Documentation"}]
2a:["$","p",null,{"children":"A crane was taken out of service for repairs. Who authorized it to go back to work? On what basis? Was it tested? Without this documentation, there's no evidence the repair was verified before the crane went back under load."}]
2b:["$","h2",null,{"children":"Preventive vs. Reactive: The Documentation Difference"}]
2c:["$","p",null,{"children":"Companies with preventive maintenance programs and documented schedules consistently face lower OSHA penalties than reactive, break-fix operations. Why? Because a documented PM program demonstrates:"}]
2d:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Good faith:"}]," You're actively trying to maintain safe equipment"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Systematic approach:"}]," Not random or personality-dependent"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Predictability:"}]," Problems get caught before they become failures"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Defensibility:"}]," If something does fail, your records show it wasn't from neglect"]}]]}]
2e:["$","p",null,{"children":"In OSHA penalty calculations, an employer's \"good faith\" can reduce penalties by up to 25%. A documented, followed PM program is one of the strongest demonstrations of good faith you can present."}]
2f:["$","h2",null,{"children":"Stop Maintaining Cranes on Paper"}]
30:["$","p",null,{"children":"The information needs to be captured at the point of work — when the mechanic finishes the job, when the part gets replaced, when the fluid gets sampled. Not reconstructed later from memory, not transcribed from a grease-stained notebook, not entered in bulk at the end of the month. Real-time documentation at the point of maintenance is the standard. Build your system to make that easy."}]
