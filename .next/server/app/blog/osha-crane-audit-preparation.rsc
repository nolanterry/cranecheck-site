t-bold mb-4 text-white","children":"How to Prepare for an OSHA Crane Audit"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl mx-auto","children":"OSHA crane audits don't have to be stressful. Learn what inspectors look for, which records they'll request, and how to be audit-ready before they arrive."}]]}]}],["$","article",null,{"className":"py-20 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand hover:prose-a:text-brand-dark prose-strong:text-navy","children":[["$","p",null,{"children":"An OSHA crane audit can happen at any time. Whether it's triggered by a complaint, a workplace accident, or a routine programmed inspection, the result is the same: a compliance officer walks onto your site and starts asking questions about your crane operations. The companies that pass without citations are the ones that prepared long before the inspector arrived."}],"$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b"]}]}],"$L3c"]}],"$L3d"],["$L3e"],"$L3f"]}],{},null,false,false]},null,false,false]},null,false,false]},null,false,false],"$L40",false]],"m":"$undefined","G":["$41",[]],"S":true}
