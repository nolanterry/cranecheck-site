9:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"OSHA Crane Inspection Requirements: The Complete 2026 Guide\",\"description\":\"Comprehensive guide to OSHA crane inspection requirements under 29 CFR 1926.1412 and 29 CFR 1910.179. Learn inspection types, frequencies, documentation rules, penalties, and how to stay compliant in 2026.\",\"datePublished\":\"2026-03-01\",\"dateModified\":\"2026-03-01\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/osha-crane-inspection-requirements\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"OSHA Crane Inspection Requirements: The Complete 2026 Guide\",\"item\":\"https://cranecheck.com/blog/osha-crane-inspection-requirements\"}]}"}}],["$","$L11",null,{}],["$","main",null,{"id":"main-content","children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Compliance"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 1, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"12 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"OSHA Crane Inspection Requirements: The Complete 2026 Guide"}],["$","p",null,{"className":"text-lg text-gray-300 leading-relaxed","children":"Everything you need to know about OSHA crane inspection requirements under 29 CFR 1926.1412 and 29 CFR 1910.179 — inspection types, frequencies, documentation rules, penalties for non-compliance, and how digital tools help you stay audit-ready."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand hover:prose-a:text-brand-dark prose-a:no-underline hover:prose-a:underline","children":[["$","p",null,{"children":"Crane inspections are not optional. Under federal law, every employer who operates cranes on a job site or in a facility is required to perform documented inspections at specific intervals. Failure to comply exposes your company to citations, fines that can exceed $165,000 per violation, and — most critically — the risk of catastrophic equipment failure."}],["$","p",null,{"children":"This guide breaks down every OSHA crane inspection requirement that applies in 2026, covering both construction cranes (29 CFR 1926 Subpart CC) and general industry overhead and gantry cranes (29 CFR 1910.179). Whether you run a fleet of mobile cranes or operate overhead bridge cranes in a manufacturing plant, you will find the specific rules, frequencies, and documentation standards that apply to your operation."}],["$","h2",null,{"children":"Why OSHA Crane Inspections Matter"}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45"]}]}]]}],"$L46"],["$L47"],"$L48"]}]
a:["$","$1","h",{"children":[null,["$","$L49",null,{"children":"$L4a"}],["$","div",null,{"hidden":true,"children":["$","$L4b",null,{"children":["$","$4c",null,{"name":"Next.Metadata","children":"$L4d"}]}]}],["$","meta",null,{"name":"next-size-adjust","content":""}]]}]
4e:I[85437,["/_next/static/chunks/3581b3831c16e326.js","/_next/static/chunks/1a280577eab7848d.js"],"Image"]
50:I[97367,["/_next/static/chunks/ff1a16fafef87110.js","/_next/static/chunks/d2be314c3ece3fbe.js"],"OutletBoundary"]
12:["$","p",null,{"children":"OSHA's crane inspection standards exist because cranes are among the most dangerous pieces of equipment on any work site. According to OSHA, crane-related incidents account for an average of 44 deaths and over 200 serious injuries per year in the United States. The overwhelming majority of these incidents involve equipment that had identifiable deficiencies — deficiencies that a proper inspection program would have caught."}]
13:["$","p",null,{"children":["Beyond safety, crane inspections are a legal obligation. OSHA compliance officers routinely request inspection records during both scheduled and unannounced audits. If your records are incomplete, illegible, or missing, you face citations regardless of whether your equipment is actually in good condition. The documentation is the proof. For a deeper look at what auditors expect, see our guide on"," ",["$","$Le",null,{"href":"/blog/osha-crane-audit-preparation","children":"how to prepare for an OSHA crane audit"}],"."]}]
14:["$","h2",null,{"children":"29 CFR 1926.1412: Construction Crane Inspection Requirements"}]
15:["$","p",null,{"children":"29 CFR 1926.1412 is the primary OSHA standard governing crane inspections on construction sites. It applies to all cranes and derricks used in construction, including mobile cranes, tower cranes, crawler cranes, and articulating cranes. The standard defines three tiers of inspection, each with its own scope and frequency."}]
16:["$","h3",null,{"children":"Shift Inspections (Before Each Shift)"}]
17:["$","p",null,{"children":"Before a crane is used on each shift, a competent person must perform a visual inspection of the equipment. This is the most frequent inspection type and is designed to catch obvious deficiencies that could cause immediate danger. Shift inspections must cover:"}]
18:["$","ul",null,{"children":[["$","li",null,{"children":"Control mechanisms for proper operation and any visible deficiencies"}],["$","li",null,{"children":"Safety devices, including anti-two-block systems, boom angle indicators, and load moment indicators"}],["$","li",null,{"children":"Wire rope reeving for compliance with manufacturer specifications"}],["$","li",null,{"children":"Operational aids and instruments for proper function"}],["$","li",null,{"children":"Ground conditions and any potential hazards in the work area"}],["$","li",null,{"children":"Hydraulic, pneumatic, and other pressurized hoses for leaks or damage"}],["$","li",null,{"children":"Hooks and latches for deformation, cracks, or wear"}],["$","li",null,{"children":"Electrical apparatus for malfunctioning, signs of damage, or deterioration"}],["$","li",null,{"children":"Tires (where applicable) for proper inflation and condition"}]]}]
19:["$","p",null,{"children":["These items must be checked every single shift. No exceptions. We break down the full checklist item by item in our"," ",["$","$Le",null,{"href":"/blog/daily-crane-inspection-checklist","children":"daily crane inspection checklist"}]," ","guide."]}]
1a:["$","h3",null,{"children":"Monthly Inspections"}]
1b:["$","p",null,{"children":"Each month, a competent person must conduct a more thorough inspection that goes beyond the daily visual check. Monthly inspections include everything covered in the shift inspection plus:"}]
1c:["$","ul",null,{"children":[["$","li",null,{"children":"A thorough inspection of the crane's structural members, looking for cracks, corrosion, deformation, or any signs of wear that affect structural integrity"}],["$","li",null,{"children":"Bolts, rivets, and other fasteners for tightness and condition"}],["$","li",null,{"children":"Sheaves and drums for cracks, wear, or rope groove damage"}],["$","li",null,{"children":"Parts such as pins, bearings, shafts, gears, rollers, and locking devices"}],["$","li",null,{"children":"Brake and clutch system components for proper adjustment and wear"}],["$","li",null,{"children":"Power plant components including filters, lines, and tank condition"}]]}]
1d:["$","p",null,{"children":"Monthly inspection records must be documented and retained for at least three months. However, most compliance experts recommend retaining records for a minimum of one year, and many companies keep them for the life of the equipment."}]
1e:["$","h3",null,{"children":"Annual / Comprehensive Inspections"}]
1f:["$","p",null,{"children":"At least once every 12 months, each crane must undergo a comprehensive inspection performed by a qualified person. This is the most detailed inspection tier and must include:"}]
20:["$","ul",null,{"children":[["$","li",null,{"children":"All items covered in shift and monthly inspections"}],["$","li",null,{"children":"A complete structural inspection, including welds, boom sections, turntable, and outrigger components"}],["$","li",null,{"children":"Load-bearing components tested or inspected per manufacturer recommendations"}],["$","li",null,{"children":"Wire ropes inspected along their entire length with documented measurements of diameter reduction, broken wires, and corrosion"}],["$","li",null,{"children":"All safety devices functionally tested under load conditions where applicable"}]]}]
21:["$","p",null,{"children":"Annual inspection documentation must be retained until the next annual inspection is completed. If a deficiency is found, the crane must be taken out of service until the issue is resolved by a qualified person."}]
22:["$","p",null,{"children":["For a detailed plain-English walkthrough of this standard, read our article on"," ",["$","$Le",null,{"href":"/blog/29-cfr-1926-1412-explained","children":"29 CFR 1926.1412 explained"}],"."]}]
23:["$","h2",null,{"children":"29 CFR 1910.179: Overhead and Gantry Crane Requirements"}]
24:["$","p",null,{"children":"If you operate overhead bridge cranes, gantry cranes, or semi-gantry cranes in a general industry setting — manufacturing plants, warehouses, steel service centers, power plants — then 29 CFR 1910.179 is the standard that governs your inspection obligations."}]
25:["$","h3",null,{"children":"Initial Inspection"}]
26:["$","p",null,{"children":"Before a new or altered crane is placed into initial service, it must undergo a complete inspection to verify that all components are in compliance with applicable standards. This inspection must be performed by a designated person and documented."}]
27:["$","h3",null,{"children":"Daily / Pre-Use Inspections"}]
28:["$","p",null,{"children":"Before each use, operators must visually inspect the crane for deficiencies that could create a hazard. These checks include:"}]
29:["$","ul",null,{"children":[["$","li",null,{"children":"All functional operating mechanisms for maladjustment or excessive wear"}],["$","li",null,{"children":"Air or hydraulic systems for leaks or deterioration"}],["$","li",null,{"children":"Hooks for deformation, cracks, excessive throat opening, or twist"}],["$","li",null,{"children":"Wire rope reeving for compliance with the crane manufacturer's recommendations"}],["$","li",null,{"children":"Hoist chains, including end connections, for excessive wear, twist, or distortion"}]]}]
2a:["$","h3",null,{"children":"Periodic (Monthly to Annual) Inspections"}]
2b:["$","p",null,{"children":"1910.179 requires frequent inspections (daily to monthly depending on severity of service) and periodic inspections (one to twelve month intervals). Periodic inspections must cover:"}]
2c:["$","ul",null,{"children":[["$","li",null,{"children":"Deformed, cracked, or corroded structural members"}],["$","li",null,{"children":"Loose bolts or rivets"}],["$","li",null,{"children":"Cracked or worn sheaves and drums"}],["$","li",null,{"children":"Worn, cracked, or distorted parts such as pins, bearings, shafts, gears, rollers, and locking or clamping devices"}],["$","li",null,{"children":"Excessive wear on brake system parts"}],["$","li",null,{"children":"Load, wind, and other indicators for accuracy"}],["$","li",null,{"children":"Power plant components for leaks, condition, and performance"}],["$","li",null,{"children":"Excessive wear of chain drive sprockets and chain"}],["$","li",null,{"children":"Travel steering, currentand, and trolley bumpers"}]]}]
2d:["$","p",null,{"children":"Cranes not in regular use that have been idle for a period of one month or more, but less than six months, must be inspected before being placed back in service. Cranes idle for more than six months require a full periodic inspection."}]
2e:["$","h2",null,{"children":"Documentation Requirements"}]
2f:["$","p",null,{"children":"OSHA does not merely require that inspections happen — it requires that they are documented. For construction cranes under 1926.1412, the documentation requirements are explicit:"}]
30:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Shift inspections:"}]," A competent person must confirm the inspection occurred. While OSHA does not mandate a specific form, a written or digital record is strongly recommended and is the only practical way to prove compliance during an audit."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Monthly inspections:"}]," Documentation is required and must be retained for a minimum of three months."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Annual inspections:"}]," Documentation is required and must be retained until the next annual inspection is completed."]}]]}]
31:["$","p",null,{"children":"For overhead cranes under 1910.179, dated inspection reports must be maintained on file where readily available to appointed personnel."}]
32:["$","p",null,{"children":"In practice, OSHA compliance officers expect to see a clear paper trail — or digital trail — that shows what was inspected, when it was inspected, who performed the inspection, and what the findings were. Missing records are treated the same as missing inspections. If you cannot produce the documentation, OSHA presumes the inspection did not occur."}]
33:["$","p",null,{"children":["This is one of the areas where"," ",["$","$Le",null,{"href":"/blog/crane-inspection-software-vs-paper","children":"digital inspection software outperforms paper logs"}]," ","dramatically. Paper forms get lost, damaged by weather, or stored in filing cabinets that nobody can search. Digital records are timestamped, geotagged, searchable, and available instantly when an auditor asks for them."]}]
34:["$","h2",null,{"children":"Penalties for Non-Compliance"}]
35:["$","p",null,{"children":"OSHA penalties for crane inspection violations are substantial and have increased steadily due to annual inflation adjustments. As of 2026, the penalty structure is:"}]
36:["$","div",null,{"className":"overflow-x-auto not-prose my-8","children":["$","table",null,{"className":"w-full text-left border border-gray-200 rounded-lg overflow-hidden text-sm","children":[["$","thead",null,{"className":"bg-navy text-white","children":["$","tr",null,{"children":[["$","th",null,{"className":"px-5 py-3 font-semibold","children":"Violation Type"}],["$","th",null,{"className":"px-5 py-3 font-semibold","children":"Maximum Penalty Per Violation"}]]}]}],["$","tbody",null,{"className":"divide-y divide-gray-100","children":[["$","tr",null,{"className":"bg-white","children":[["$","td",null,{"className":"px-5 py-3","children":"Other-Than-Serious"}],["$","td",null,{"className":"px-5 py-3","children":"$$16,550"}]]}],["$","tr",null,{"className":"bg-gray-50","children":[["$","td",null,{"className":"px-5 py-3","children":"Serious"}],["$","td",null,{"className":"px-5 py-3","children":"$$16,550"}]]}],["$","tr",null,{"className":"bg-white","children":[["$","td",null,{"className":"px-5 py-3","children":"Failure to Abate"}],["$","td",null,{"className":"px-5 py-3","children":"$$16,550 per day"}]]}],["$","tr",null,{"className":"bg-gray-50","children":[["$","td",null,{"className":"px-5 py-3 font-semibold text-red-700","children":"Willful or Repeated"}],["$","td",null,{"className":"px-5 py-3 font-semibold text-red-700","children":"$$165,514"}]]}]]}]]}]}]
37:["$","p",null,{"children":["Willful violations — which include knowingly failing to perform required inspections or falsifying inspection records — carry the maximum penalty of ",["$","strong",null,{"children":"$$165,514 per violation"}],". These penalties are per violation, not per inspection. A single audit that uncovers systematic non-compliance across multiple cranes can result in six-figure or even seven-figure total penalties."]}]
38:["$","p",null,{"children":"Beyond fines, OSHA violations become public record. They appear in the OSHA inspection database and can affect your ability to win contracts, maintain insurance coverage, and retain qualified operators."}]
39:["$","h2",null,{"children":"Who Can Perform Crane Inspections?"}]
3a:["$","p",null,{"children":"OSHA defines specific qualification levels for inspection personnel:"}]
3b:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Competent person:"}]," Required for shift and monthly inspections under 1926.1412. A competent person is someone capable of identifying existing and predictable hazards and who has the authority to take corrective action."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Qualified person:"}]," Required for annual and comprehensive inspections. A qualified person has a recognized degree, certificate, or professional standing, or has demonstrated knowledge and ability through extensive experience."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Designated person:"}]," Used in 1910.179 for overhead cranes. A person selected or assigned by the employer as being competent to perform specific duties."]}]]}]
3c:["$","p",null,{"children":"For construction cranes, many companies require NCCCO certification for their crane inspectors, even when OSHA does not explicitly mandate it, because it provides clear documentation of qualification."}]
3d:["$","h2",null,{"children":"How Digital Inspection Software Helps You Stay Compliant"}]
3e:["$","p",null,{"children":"Meeting OSHA crane inspection requirements is not just about knowing the rules — it is about executing them consistently across every crane, every shift, every month, and every year. That is where the process breaks down for most companies. The inspections happen, but the documentation is inconsistent, incomplete, or scattered across trucks, trailers, and filing cabinets."}]
3f:["$","p",null,{"children":"Purpose-built crane inspection software like CraneCheck solves this problem by digitizing every step of the inspection workflow:"}]
40:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Standardized digital checklists"}]," mapped directly to 29 CFR 1926.1412 and 29 CFR 1910.179, so inspectors never miss a required item"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Automatic scheduling and reminders"}]," for monthly and annual inspections, eliminating the risk of missed deadlines"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Timestamped, geotagged records"}]," that prove when and where each inspection occurred — exactly what auditors want to see"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Photo documentation"}]," attached directly to inspection items, providing visual evidence of equipment condition"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Deficiency tracking"}]," with automatic escalation, ensuring that identified issues are resolved before the crane returns to service"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Instant audit reports"}]," generated in PDF format, ready to hand to an OSHA compliance officer within minutes of a request"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Equipment registry"}]," with complete inspection history for every crane in your fleet, searchable by date, inspector, or deficiency status"]}]]}]
41:["$","p",null,{"children":"The difference between companies that pass OSHA audits smoothly and companies that scramble is rarely about whether inspections are actually performed. It is about whether the documentation is organized, complete, and immediately accessible. Digital inspection software makes that the default, not the exception."}]
42:["$","h2",null,{"children":"Key Takeaways"}]
43:["$","ul",null,{"children":[["$","li",null,{"children":"OSHA requires shift, monthly, and annual inspections for construction cranes under 29 CFR 1926.1412, and daily through periodic inspections for overhead cranes under 29 CFR 1910.179."}],["$","li",null,{"children":"Documentation is not optional. Missing records are treated as missing inspections during audits."}],["$","li",null,{"children":"Willful violations carry penalties up to $165,514 per violation, and these penalties are assessed per crane, per instance."}],["$","li",null,{"children":"Only competent or qualified persons may perform inspections, depending on the inspection type."}],["$","li",null,{"children":"Digital inspection software eliminates the documentation gaps that cause most OSHA citations related to crane inspections."}]]}]
