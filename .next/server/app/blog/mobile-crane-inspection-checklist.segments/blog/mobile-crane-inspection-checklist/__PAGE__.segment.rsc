0:{"buildId":"TQLm2M3A0FE1WvEGzky7S","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","main",null,{"children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Checklists"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 7, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"11 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"Mobile Crane Inspection Checklist: Complete Field Guide"}],["$","p",null,{"className":"text-lg text-gray-300 leading-relaxed","children":"A comprehensive pre-operation inspection checklist for all-terrain, rough-terrain, and truck-mounted mobile cranes. Covers hydraulic systems, outriggers, load moment indicators, wire rope, and all OSHA-required inspection items for daily compliance."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand hover:prose-a:text-brand-dark prose-a:no-underline hover:prose-a:underline","children":[["$","p",null,{"children":"Mobile cranes — whether all-terrain, rough-terrain, truck-mounted, or crawler-mounted — are complex machines with hundreds of components that must function correctly before every lift. A single overlooked deficiency can result in equipment failure, property damage, serious injury, or death. That's why OSHA mandates comprehensive pre-shift inspections under 29 CFR 1926.1412(d)."}],["$","p",null,{"children":"This checklist provides a systematic approach to mobile crane pre-operation inspections. It's organized by major system to ensure nothing gets missed, whether you're operating a 40-ton all-terrain crane on a construction site or a 500-ton rough-terrain crane for heavy industrial work. Every item listed here is either required by OSHA or represents a critical safety check that experienced operators know to perform."}],["$","h2",null,{"children":"Pre-Inspection Safety Requirements"}],["$","p",null,{"children":"Before beginning the physical inspection, establish proper safety protocols:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Engine off, parking brake set, and key removed from the ignition"}],["$","li",null,{"children":"All hydraulic systems depressurized according to manufacturer procedures"}],["$","li",null,{"children":"Boom lowered to the travel position or adequately supported if maintenance requires boom elevation"}],["$","li",null,{"children":"Load block secured or removed to prevent swing during inspection"}],["$","li",null,{"children":"Personal protective equipment (hard hat, safety glasses, high-visibility vest) worn throughout inspection"}],["$","li",null,{"children":"Adequate lighting provided if inspection occurs before dawn or after dusk"}]]}],["$","p",null,{"children":"Never perform an inspection while the crane is running unless the specific procedure requires engine operation (such as testing hydraulic function). If engine operation is necessary, ensure adequate clearance from rotating components and never place body parts near pinch points or moving machinery."}],["$","h2",null,{"children":"Visual Walk-Around Inspection"}],["$","p",null,{"children":"Begin every mobile crane inspection with a complete walk-around of the entire machine. This initial survey helps identify obvious problems and provides an overview of the equipment's general condition before diving into system-specific checks."}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43","$L44","$L45","$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c"]}]}]]}],"$L4d"],["$L4e","$L4f"],"$L50"]}],"loading":null,"isPartial":false}
3:["$","h3",null,{"children":"Structural Components"}]
4:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Boom sections:"}]," Check all boom sections for cracks, dents, corrosion, or deformation. Pay special attention to weld seams, boom heel pins, and telescopic sections. Look for hydraulic fluid leaks around extension cylinders."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Upper frame:"}]," Inspect the turntable bearing, counterweight, and upper frame for structural damage, loose bolts, or cracked welds. Check the swing motor and gearbox for leaks."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lower frame:"}]," Examine the carrier frame, axles, and suspension components for damage. Look for stress cracks near outrigger mounting points, which are high-load areas."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cab structure:"}]," Verify that the operator's cab is securely mounted with no loose bolts or cracked glass. Check that doors operate properly and safety glass is intact."]}]]}]
5:["$","h3",null,{"children":"Ground Conditions and Setup Area"}]
6:["$","ul",null,{"children":[["$","li",null,{"children":"Ground bearing capacity adequate for crane size and planned loads"}],["$","li",null,{"children":"Level setup area within manufacturer's specified grade limitations (typically 1% for mobile cranes)"}],["$","li",null,{"children":"No underground utilities, voids, or soft spots in the setup area"}],["$","li",null,{"children":"Adequate clearance from power lines, structures, and other hazards"}],["$","li",null,{"children":"Proper crane positioning for planned lifts without exceeding load chart ratings"}]]}]
7:["$","h2",null,{"children":"Outrigger and Stabilizer System"}]
8:["$","p",null,{"children":"The outrigger system is critical for mobile crane stability. Most mobile crane accidents involve tip-overs caused by inadequate outrigger setup or outrigger system failure. Inspect each outrigger float, beam, and cylinder thoroughly."}]
9:["$","h3",null,{"children":"Outrigger Floats and Pads"}]
a:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Float condition:"}]," Check each outrigger float for cracks, especially around the cylinder attachment point and pad edges. Bent or cracked floats must be replaced before operation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Float size:"}]," Verify that float size matches manufacturer specifications for the crane model and ground conditions. Oversized floats may be required for soft ground."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cribbing and blocking:"}]," Ensure adequate cribbing is available if required by ground conditions. Cribbing must be hardwood, engineered lumber, or manufactured crib blocks rated for the load."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Float attachment:"}]," Check that floats are properly attached to outrigger beams with all pins and hardware secure."]}]]}]
b:["$","h3",null,{"children":"Outrigger Beams and Cylinders"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Beam extension:"}]," Inspect outrigger beams for straight extension and proper retraction. Bent or binding beams indicate internal damage or misalignment."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cylinder condition:"}]," Check outrigger cylinders for fluid leaks, bent rods, or damaged seals. Look for scratches or scoring on cylinder rods that can damage seals."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hydraulic lines:"}]," Inspect all hydraulic lines and fittings for leaks, abrasion, or damage. Pay attention to lines that flex during outrigger operation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Relief valves:"}]," Verify that outrigger relief valves are set to manufacturer specifications. These prevent over-pressurization during setup."]}]]}]
d:["$","h3",null,{"children":"Outrigger Operation Test"}]
e:["$","p",null,{"children":"After visual inspection, test outrigger operation with the engine running:"}]
f:["$","ul",null,{"children":[["$","li",null,{"children":"Extend each outrigger beam to full extension and verify smooth operation without binding or unusual noise"}],["$","li",null,{"children":"Set outrigger floats to full load-carrying position and confirm crane lifts evenly off all tires"}],["$","li",null,{"children":"Test outrigger float pressure relief if equipped — floats should not sink under load once properly set"}],["$","li",null,{"children":"Verify level bubble indicators show crane is level within manufacturer specifications (typically ±1 degree)"}]]}]
10:["$","h2",null,{"children":"Hydraulic System Inspection"}]
11:["$","p",null,{"children":"Mobile cranes rely entirely on hydraulic power for boom operation, load handling, and outrigger deployment. Hydraulic system failure can cause immediate loss of load control. A thorough hydraulic inspection is essential for safe operation."}]
12:["$","h3",null,{"children":"Hydraulic Fluid and Reservoir"}]
13:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Fluid level:"}]," Check hydraulic fluid level with all cylinders retracted and boom lowered. Fluid should be between minimum and maximum marks on the sight gauge."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Fluid condition:"}]," Inspect hydraulic fluid for contamination, water, or burnt smell. Dark or milky fluid indicates contamination that can damage system components."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Filter condition:"}]," Check hydraulic filter indicators if equipped. Replace filters when indicator shows red or according to manufacturer service intervals."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Reservoir condition:"}]," Inspect the hydraulic reservoir for damage, loose fittings, or signs of overheating. Check the breather cap for proper operation."]}]]}]
14:["$","h3",null,{"children":"Hydraulic Pumps and Motors"}]
15:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Main hydraulic pump:"}]," Check for unusual noise, vibration, or overheating during operation. Pump noise often indicates internal wear or contamination."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Auxiliary pumps:"}]," If equipped with pilot hydraulics or auxiliary circuits, test all pumps for proper operation and pressure."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hydraulic motors:"}]," Test swing motor, winch motors, and any auxiliary hydraulic motors for smooth operation and proper speed control."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cooling system:"}]," Verify hydraulic oil cooler is clean and free of debris. Overheating damages hydraulic components and reduces system life."]}]]}]
16:["$","h3",null,{"children":"Hydraulic Cylinders and Lines"}]
17:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Boom lift cylinders:"}]," Inspect boom lift cylinders for leaks, bent rods, or damaged seals. Test cylinder drift with boom raised — excessive drift indicates worn seals."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Boom extend cylinders:"}]," Check telescopic boom cylinders for proper extension and retraction. Listen for unusual noises that may indicate internal damage."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hydraulic lines:"}]," Inspect all hydraulic lines for abrasion, cuts, or bulging. Pay special attention to lines that move during crane operation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Fittings and connections:"}]," Check all hydraulic fittings for leaks or loose connections. Even small leaks can lead to system failure and create slip hazards."]}]]}]
18:["$","h2",null,{"children":"Load Moment Indicator (LMI) System"}]
19:["$","p",null,{"children":"The Load Moment Indicator is a critical safety system that prevents crane overload by monitoring boom angle, boom length, and load weight in real-time. OSHA requires LMI systems on most mobile cranes, and proper testing is mandatory during pre-operation inspection."}]
1a:["$","h3",null,{"children":"LMI Display and Controls"}]
1b:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Display function:"}]," Verify LMI display shows all required information clearly — boom angle, boom length, rated load, and actual load percentage. Replace cracked or dim displays."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Audio alarms:"}]," Test LMI audio warnings at 90% and 100% of rated capacity. Alarms must be audible to the operator over engine and work noise."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Visual warnings:"}]," Check LMI warning lights for proper operation. Most systems use amber warnings at 90% capacity and red warnings at 100%."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Function lockouts:"}]," Verify that LMI prevents boom lowering, boom extension, and increased load when at 100% capacity. The system must allow only load-reducing movements."]}]]}]
1c:["$","h3",null,{"children":"LMI Calibration and Testing"}]
1d:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Load block test:"}]," With the load block freely suspended, verify LMI shows the correct block weight. Most systems should read within ±3% of actual block weight."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Boom angle calibration:"}]," Check boom angle readings against a physical inclinometer at multiple boom positions. Accuracy should be within ±1 degree."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Boom length verification:"}]," For telescopic cranes, verify boom length readings match actual extended length. Check calibration at minimum, maximum, and intermediate lengths."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Load chart verification:"}]," Confirm LMI uses the correct load chart for the current crane configuration, including boom length, jib installation, and counterweight configuration."]}]]}]
1e:["$","p",null,{"children":"If the LMI system fails any test, the crane must be removed from service until repairs are completed by a qualified technician. Never bypass or override LMI safety systems for any reason."}]
1f:["$","h2",null,{"children":"Wire Rope and Rigging Hardware"}]
20:["$","p",null,{"children":"Wire rope failure is a leading cause of crane accidents. OSHA requires detailed wire rope inspection before each use, with specific criteria for determining when rope must be replaced. This inspection must cover the entire length of rope, not just the visible portions."}]
21:["$","h3",null,{"children":"Main Hoist Wire Rope"}]
22:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Broken wires:"}]," Count broken wires in each rope lay (one complete wrap around the rope). ASME B30.5 requires replacement when more than 6 randomly distributed broken wires are found in one lay, or 3 broken wires in one strand in one lay."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Rope diameter:"}]," Measure rope diameter at multiple points with calipers. Replace rope when diameter reduction exceeds 7% of nominal diameter due to wear or corrosion."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Corrosion:"}]," Inspect for external and internal corrosion. Internal corrosion may not be visible and requires opening rope lays for inspection. Pitting corrosion is particularly dangerous."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Kinking and crushing:"}]," Look for kinked, bird-caged, or crushed areas. These indicate overloading or improper handling and require immediate rope replacement."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lubrication:"}]," Verify rope is properly lubricated. Dry rope wears quickly and is more susceptible to corrosion. Fresh lubrication should be visible on rope surface."]}]]}]
23:["$","h3",null,{"children":"Load Block and Hook Inspection"}]
24:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Hook condition:"}]," Inspect hook for cracks using magnetic particle or dye penetrant testing if required. Check for throat opening increase — replace hook if throat opening has increased 15% or twist exceeds 10 degrees."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Hook latch operation:"}]," Test hook latch for proper operation and spring return. Latch must close completely and lock securely."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Load block sheaves:"}]," Check load block sheaves for proper rope seating, adequate lubrication, and smooth rotation. Look for rope groove wear or damage."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Load block bearing:"}]," Verify load block swivels freely on its bearing. Binding or rough rotation indicates bearing problems."]}]]}]
25:["$","h3",null,{"children":"Boom Head and Auxiliary Winch"}]
26:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Boom head sheaves:"}]," Inspect boom head sheaves for rope groove wear, cracked side plates, or damaged bearings. Sheaves must turn freely and maintain proper rope alignment."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Auxiliary winch rope:"}]," If equipped with an auxiliary winch, inspect that wire rope using the same criteria as main hoist rope. Auxiliary winches often use smaller diameter rope that wears faster."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Rope reeving:"}]," Verify wire rope is reeved according to manufacturer specifications. Improper reeving reduces capacity and can cause rope damage."]}]]}]
27:["$","p",null,{"children":["For a detailed guide on wire rope inspection criteria and replacement standards, see our comprehensive article on"," ",["$","$L51",null,{"href":"/blog/crane-wire-rope-inspection-guide","children":"crane wire rope inspection"}],"."]}]
28:["$","h2",null,{"children":"Engine and Power Plant"}]
29:["$","p",null,{"children":"Mobile cranes typically use diesel engines to power both the carrier and the hydraulic systems. Engine problems can leave a crane stranded on site or cause hydraulic system failure during critical lifts."}]
2a:["$","h3",null,{"children":"Engine Operation and Performance"}]
2b:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Starting system:"}]," Engine should start readily without excessive cranking or visible exhaust smoke. Check that all warning lights function during startup."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Idle quality:"}]," Engine should idle smoothly without irregular operation or stalling. Rough idle may indicate fuel system or engine problems."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Operating temperature:"}]," Verify engine reaches normal operating temperature and cooling system maintains proper temperature under load."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Oil pressure:"}]," Check engine oil pressure at idle and operating RPM. Low oil pressure can cause catastrophic engine damage."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Exhaust system:"}]," Inspect exhaust system for leaks, damage, or excessive smoke production during operation."]}]]}]
2c:["$","h3",null,{"children":"Cooling and Filtration Systems"}]
2d:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Radiator condition:"}]," Check radiator for leaks, damage, or debris accumulation. Clean radiator fins regularly to maintain cooling efficiency."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Coolant level:"}]," Verify coolant level in both radiator and overflow tank. Check coolant condition — contaminated coolant should be replaced."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Air filter:"}]," Inspect air filter for contamination or damage. Dirty air filters reduce engine power and increase fuel consumption."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Fuel system:"}]," Check fuel level and fuel quality. Look for water or contamination in fuel tank. Inspect fuel lines for leaks or damage."]}]]}]
2e:["$","h2",null,{"children":"Control Systems and Safety Devices"}]
2f:["$","p",null,{"children":"Modern mobile cranes incorporate multiple safety systems and control mechanisms that must function properly for safe operation. Test all controls and safety systems during pre-operation inspection."}]
30:["$","h3",null,{"children":"Operator Controls"}]
31:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Joystick operation:"}]," Test all hydraulic function joysticks for smooth operation, proper return to neutral, and correct response direction."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Travel controls:"}]," If equipped with operator travel controls, test steering, transmission, and brake operation from the operator's station."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Winch controls:"}]," Test main winch and auxiliary winch controls for proper operation, including load lowering and free-fall functions if equipped."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Emergency stops:"}]," Test all emergency stop buttons and ensure they immediately stop all crane functions when activated."]}]]}]
32:["$","h3",null,{"children":"Safety and Warning Systems"}]
33:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Anti-two-block system:"}]," Test anti-two-block protection by raising load block to the boom head. System must stop hoist function before contact occurs."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Boom angle indicator:"}]," Verify boom angle indicator accuracy against a calibrated inclinometer at multiple boom positions."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Warning beepers:"}]," Test travel warning beepers, backup alarms, and any other audible warning devices for proper operation and adequate volume."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Work lights:"}]," Check all work lights, warning lights, and navigation lights for proper operation. Replace burned-out bulbs immediately."]}]]}]
34:["$","h2",null,{"children":"Carrier and Travel Systems"}]
35:["$","p",null,{"children":"Mobile cranes must be capable of safe travel to and from job sites. Inspect all carrier systems that affect transportation safety and on-site mobility."}]
36:["$","h3",null,{"children":"Tires and Wheels"}]
37:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Tire condition:"}]," Inspect all tires for cuts, bulges, uneven wear, or foreign objects. Check tire tread depth and sidewall condition."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Tire pressure:"}]," Verify all tires are inflated to manufacturer specifications. Under-inflated tires reduce crane stability and increase tire wear."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Wheel mounting:"}]," Check that all wheels are properly mounted with correct lug nut torque. Look for loose or missing lug nuts."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Wheel bearings:"}]," Check for excessive wheel bearing play or noise during operation. Worn bearings can cause wheel separation."]}]]}]
38:["$","h3",null,{"children":"Steering and Braking Systems"}]
39:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Steering operation:"}]," Test steering for proper operation in all steering modes (front, rear, all-wheel, crab). Steering should be responsive without excessive play."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Service brakes:"}]," Test service brakes for proper operation and adequate stopping power. Brake pedal should be firm without excessive travel."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Parking brake:"}]," Verify parking brake holds crane securely on maximum grade the crane will encounter. Test parking brake warning indicators."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Air brakes:"}]," If equipped with air brakes, check air pressure, air dryer operation, and emergency brake function. Low air pressure warnings must activate properly."]}]]}]
3a:["$","h2",null,{"children":"Documentation and Record Keeping"}]
3b:["$","p",null,{"children":"OSHA requires documentation of daily crane inspections under 29 CFR 1926.1412(d). While the standard does not mandate a specific form, written documentation is the only practical way to prove compliance during an audit."}]
3c:["$","h3",null,{"children":"Required Documentation Elements"}]
3d:["$","ul",null,{"children":[["$","li",null,{"children":"Date and time of inspection"}],["$","li",null,{"children":"Crane identification (serial number, fleet number, or other unique identifier)"}],["$","li",null,{"children":"Name and signature of competent person performing inspection"}],["$","li",null,{"children":"List of all items inspected with pass/fail status"}],["$","li",null,{"children":"Description of any deficiencies found and corrective action taken"}],["$","li",null,{"children":"Confirmation that crane is safe for operation or out-of-service status if deficiencies were found"}]]}]
3e:["$","h3",null,{"children":"Digital Inspection Advantages"}]
3f:["$","p",null,{"children":"Many contractors are moving from paper inspection forms to digital inspection software for several compelling reasons:"}]
40:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Standardization:"}]," Digital checklists ensure the same inspection items are checked on every crane, every day, eliminating the variability that comes with handwritten forms."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Photo documentation:"}]," Digital systems allow photos to be attached directly to inspection items, providing visual evidence of equipment condition."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Automatic scheduling:"}]," Software can track inspection schedules and send reminders for monthly and annual inspections, preventing missed deadlines."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Instant reports:"}]," Digital systems generate formatted inspection reports instantly, ready for OSHA auditors or insurance inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Searchable records:"}]," Digital records can be searched by date, crane, inspector, or deficiency type, something impossible with paper files."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Weather resistance:"}]," Digital records don't get lost in the rain, blown away by wind, or damaged by hydraulic fluid spills."]}]]}]
41:["$","p",null,{"children":["For more information on the advantages of digital inspection systems, see our comparison of"," ",["$","$L51",null,{"href":"/blog/crane-inspection-software-vs-paper","children":"crane inspection software vs paper logs"}],"."]}]
42:["$","h2",null,{"children":"Common Inspection Mistakes to Avoid"}]
43:["$","p",null,{"children":"Even experienced operators and inspectors can fall into common traps that compromise inspection effectiveness:"}]
44:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Rushing the inspection:"}]," Pre-operation inspections take time. Allow adequate time for a thorough inspection rather than rushing to start work."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Skipping difficult-to-reach areas:"}]," Components that are hard to access often receive inadequate inspection. Use proper lighting and access equipment to inspect all areas."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Ignoring minor deficiencies:"}]," Small problems often become major failures. Address minor issues promptly before they compromise safety."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Inadequate documentation:"}]," Vague inspection records like \"OK\" or \"checked\" provide no useful information. Document what you actually inspected and what you found."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Operating with known deficiencies:"}]," Never operate a crane with known safety-related deficiencies, even if they seem minor. Remove the crane from service until repairs are completed."]}]]}]
45:["$","h2",null,{"children":"When to Take Equipment Out of Service"}]
46:["$","p",null,{"children":"Any deficiency that affects crane safety must result in immediately taking the equipment out of service. This includes:"}]
47:["$","ul",null,{"children":[["$","li",null,{"children":"LMI system malfunction or inaccurate readings"}],["$","li",null,{"children":"Wire rope that exceeds replacement criteria"}],["$","li",null,{"children":"Hydraulic system leaks that affect operation"}],["$","li",null,{"children":"Structural damage to boom, frame, or outrigger components"}],["$","li",null,{"children":"Brake system problems that affect stopping ability"}],["$","li",null,{"children":"Any safety system malfunction (anti-two-block, warning alarms, etc.)"}],["$","li",null,{"children":"Control system problems that affect operator ability to safely control the crane"}]]}]
48:["$","p",null,{"children":"Equipment taken out of service must be clearly tagged and secured to prevent unauthorized use. Only a qualified person may return equipment to service after verifying that all deficiencies have been corrected."}]
49:["$","h2",null,{"children":"Key Takeaways"}]
4a:["$","ul",null,{"children":[["$","li",null,{"children":"Mobile crane pre-operation inspections are required by OSHA before every shift and must be documented by a competent person."}],["$","li",null,{"children":"Systematic inspection of outriggers, hydraulics, LMI systems, wire rope, and carrier components is essential for safe operation."}],["$","li",null,{"children":"LMI systems must be tested for accuracy and proper alarm function — never bypass or override these safety systems."}],["$","li",null,{"children":"Wire rope inspection requires checking the entire length for broken wires, diameter reduction, corrosion, and other damage according to ASME B30.5 standards."}],["$","li",null,{"children":"Digital inspection software provides significant advantages over paper forms for documentation, standardization, and audit compliance."}],["$","li",null,{"children":"Any safety-related deficiency must result in immediately taking the crane out of service until repairs are completed by qualified personnel."}]]}]
