9:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Overhead Crane Inspection Frequency: OSHA vs ASME Requirements\",\"description\":\"Understand overhead crane inspection frequency requirements under OSHA 1910.179 and ASME B30.2. Daily, monthly, quarterly, and annual inspection schedules explained for safety directors and crane operators.\",\"datePublished\":\"2026-03-08\",\"dateModified\":\"2026-03-08\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/overhead-crane-inspection-frequency\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Overhead Crane Inspection Frequency: OSHA vs ASME Requirements\",\"item\":\"https://cranecheck.com/blog/overhead-crane-inspection-frequency\"}]}"}}],["$","$L11",null,{}],["$","$L12",null,{}],["$","main",null,{"id":"main-content","children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Compliance"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 8, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"12 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"Overhead Crane Inspection Frequency: OSHA vs ASME Requirements"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl","children":"How often should you inspect overhead cranes? The answer depends on which standard you follow, what type of service the crane sees, and whether your state enforces additional requirements. This guide breaks down every inspection interval."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-strong:text-navy","children":[["$","div",null,{"className":"not-prose","children":["$","$L13",null,{}]}],["$","p",null,{"children":["Overhead cranes operate in factories, warehouses, steel mills, and fabrication shops across every industry. They lift heavy loads, often over workers, hundreds of times per day. The inspection frequency requirements for these cranes are governed by two overlapping frameworks: ",["$","strong",null,{"children":"OSHA 1910.179"}]," (federal regulation) and ",["$","strong",null,{"children":"ASME B30.2"}]," (consensus standard). Understanding both is not optional — it is the baseline for keeping your facility compliant and your workers alive."]}],["$","h2",null,{"children":"The Two Standards You Must Know"}],["$","p",null,{"children":"OSHA and ASME are not the same thing, and they do not always agree. Here is the critical distinction:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"OSHA 1910.179"}]," is a federal regulation. It is legally enforceable. Violations result in citations and fines. It applies to all overhead and gantry cranes in general industry."]}],"$L14"]}],"$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35"]}]}],"$L36","$L37"]}],"$L38"],["$L39","$L3a"],"$L3b"]}]
a:["$","$1","h",{"children":[null,["$","$L3c",null,{"children":"$L3d"}],["$","div",null,{"hidden":true,"children":["$","$L3e",null,{"children":["$","$3f",null,{"name":"Next.Metadata","children":"$L40"}]}]}],["$","meta",null,{"name":"next-size-adjust","content":""}]]}]
