44:I[97367,["/_next/static/chunks/ff1a16fafef87110.js","/_next/static/chunks/d2be314c3ece3fbe.js"],"OutletBoundary"]
14:["$","li",null,{"children":[["$","strong",null,{"children":"ASME B30.2"}]," is a voluntary consensus standard published by the American Society of Mechanical Engineers. It is more detailed and more frequently updated than the OSHA standard. Many states and insurance companies require compliance with ASME B30.2 even though it is not itself a federal regulation."]}]
15:["$","p",null,{"children":"In practice, you should follow whichever is more stringent. In almost every case, that is ASME B30.2. OSHA inspectors routinely reference ASME standards when evaluating compliance, and courts have upheld citations based on ASME best practices under the General Duty Clause."}]
16:["$","h2",null,{"children":"Daily (Pre-Use) Inspections"}]
17:["$","p",null,{"children":"Both OSHA and ASME require a visual inspection before each shift or each use of the crane. Under OSHA 1910.179(j)(2), operators must check for:"}]
18:["$","ul",null,{"children":[["$","li",null,{"children":"All functional operating mechanisms for maladjustment interfering with proper operation"}],["$","li",null,{"children":"Deterioration or leakage in lines, tanks, valves, drain pumps, and other parts of air or hydraulic systems"}],["$","li",null,{"children":"Hooks with deformations or cracks (see ASME B30.10 for hook inspection criteria)"}],["$","li",null,{"children":"Hoist chains, including end connections, for excessive wear, twist, distorted links, or stretch"}],["$","li",null,{"children":"All functional operating mechanisms for excessive wear of components"}],["$","li",null,{"children":"Rope reeving for noncompliance with manufacturer recommendations"}]]}]
19:["$","p",null,{"children":["ASME B30.2-2024 Section 2-2.2.2 categorizes these as ",["$","strong",null,{"children":"frequent inspections"}]," — items checked daily to monthly depending on crane service. For cranes in continuous or severe service, daily is the minimum. For cranes in normal or light service, the interval can extend to monthly for some items, but ",["$","strong",null,{"children":"pre-shift operational checks are always required"}],"."]}]
1a:["$","h2",null,{"children":"Monthly (Frequent) Inspections"}]
1b:["$","p",null,{"children":"ASME B30.2 defines frequent inspections as those performed at intervals of daily to monthly depending on the activity level of the crane. Monthly inspections should cover everything in the daily checklist plus:"}]
1c:["$","ul",null,{"children":[["$","li",null,{"children":"Deterioration or leakage in lines, tanks, valves, drain pumps"}],["$","li",null,{"children":"Hooks — check latch engagement, throat opening measurement, twist exceeding 10 degrees"}],["$","li",null,{"children":"Hoist chains — check for stretch beyond manufacturer limits"}],["$","li",null,{"children":"Wire rope — check for broken wires, corrosion, kinking, crushing, bird-caging"}],["$","li",null,{"children":"All functional operating mechanisms for excessive component wear"}],["$","li",null,{"children":"Control and safety devices — verify limit switches, emergency stops function"}]]}]
1d:["$","p",null,{"children":["Monthly inspections should be documented. While OSHA 1910.179 does not explicitly require written records for frequent inspections, ASME B30.2 does, and best practice is to always create a record. ",["$","$Le",null,{"href":"/blog/crane-inspection-software-vs-paper","children":"Digital inspection logs"}]," eliminate the ambiguity — every check is timestamped, signed, and stored."]}]
1e:["$","h2",null,{"children":"Quarterly Inspections"}]
1f:["$","p",null,{"children":"Neither OSHA 1910.179 nor ASME B30.2 explicitly defines a quarterly inspection tier. However, many facilities adopt quarterly intervals for items that fall between monthly and annual categories. Common quarterly inspection items include:"}]
20:["$","ul",null,{"children":[["$","li",null,{"children":"Wire rope replacement evaluation (measuring diameter reduction, broken wire count per lay length)"}],["$","li",null,{"children":"Brake adjustment and wear assessment"}],["$","li",null,{"children":"Electrical system checks — contactors, resistors, collector shoes"}],["$","li",null,{"children":"Runway and bridge alignment verification"}],["$","li",null,{"children":"Lubrication schedule compliance review"}]]}]
21:["$","p",null,{"children":"Quarterly inspections are a practical middle ground. Waiting a full year between periodic inspections for high-use cranes is risky. If your crane lifts rated capacity regularly or operates in a corrosive environment, quarterly checks on wear components are a defensible practice."}]
22:["$","h2",null,{"children":"Annual (Periodic) Inspections"}]
23:["$","p",null,{"children":"This is where the requirements get serious. Both OSHA and ASME require periodic inspections at intervals of one to twelve months depending on crane service. For most facilities, annual is the standard interval."}]
24:["$","p",null,{"children":"Under OSHA 1910.179(j)(3), periodic inspections must cover:"}]
25:["$","ul",null,{"children":[["$","li",null,{"children":"Deformed, cracked, or corroded members in the crane structure"}],["$","li",null,{"children":"Loose bolts or rivets"}],["$","li",null,{"children":"Cracked or worn sheaves and drums"}],["$","li",null,{"children":"Worn, cracked, or distorted parts such as pins, bearings, shafts, gears, rollers, locking and clamping devices"}],["$","li",null,{"children":"Excessive wear on brake system parts"}],["$","li",null,{"children":"Load, wind, and other indicators for inoperability"}],["$","li",null,{"children":"Gasoline, diesel, electric, or other power plants for improper performance"}],["$","li",null,{"children":"Excessive wear of chain drive sprocket and chain"}],["$","li",null,{"children":"Electrical apparatus for signs of pitting or deterioration of contacts, controllers, limit switches, and pushbutton stations"}],["$","li",null,{"children":"Travel, trolley, and bridge bumpers"}]]}]
26:["$","p",null,{"children":["ASME B30.2 Section 2-2.2.3 expands this list significantly and requires that periodic inspections be performed by a ",["$","strong",null,{"children":"designated person"}]," — someone who is qualified by knowledge, training, and experience to perform the inspection."]}]
27:["$","p",null,{"children":[["$","strong",null,{"children":"Annual inspections must be documented."}]," Both OSHA and ASME require written records. These records must include: the date, the items inspected, the condition of each item, the name of the inspector, and any corrective actions taken. This is non-negotiable. If you cannot produce these records during an OSHA audit, you will be cited."]}]
28:["$","h2",null,{"children":"Inspection Frequency by Service Classification"}]
29:["$","p",null,{"children":"ASME B30.2 categorizes crane service into classes that affect inspection frequency:"}]
2a:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Standby or infrequent service"}]," — crane sits idle for long periods, used infrequently. Inspect before each use; periodic inspection annually minimum."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Light service"}]," — loads well below rated capacity, 2-5 lifts per hour. Monthly frequent inspections; annual periodic inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Moderate service"}]," — loads average 50% of rated capacity, 5-10 lifts per hour. Monthly frequent inspections; semi-annual periodic inspections recommended."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Heavy service"}]," — loads approaching rated capacity, 10-20 lifts per hour. Weekly frequent inspections; semi-annual periodic inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Severe service"}]," — rated capacity loads throughout lifecycle, 20+ lifts per hour. Daily frequent inspections; quarterly periodic inspections."]}]]}]
2b:["$","p",null,{"children":"Most facilities underestimate their service classification. A steel service center lifting coils all day is severe service, not moderate. A precast concrete plant running a 50-ton crane at capacity is severe. Classify honestly — it determines your minimum inspection intervals."}]
2c:["$","h2",null,{"children":"What Happens When You Miss an Inspection"}]
2d:["$","p",null,{"children":["OSHA penalties for crane inspection violations under 1910.179 range from ",["$","strong",null,{"children":"$$16,131 per serious violation"}]," to ",["$","strong",null,{"children":"$$161,323 per willful violation"}]," (2024 penalty amounts, adjusted annually). Missing a required annual inspection is typically cited as serious. Missing inspections after a known deficiency can escalate to willful."]}]
2e:["$","p",null,{"children":["Beyond fines, the real cost is liability. If a crane fails and your inspection records show a gap, plaintiff attorneys will use that gap to establish negligence. Documented, consistent inspections are your first line of defense in any incident investigation. See our guide on ",["$","$Le",null,{"href":"/blog/crane-inspection-penalties-fines","children":"OSHA crane penalties and fines"}]," for a full breakdown."]}]
2f:["$","h2",null,{"children":"Building an Inspection Schedule That Works"}]
30:["$","p",null,{"children":"The most common failure is not a lack of knowledge — it is a lack of systems. Safety directors know the requirements. The problem is tracking dozens of cranes across multiple intervals with paper forms and spreadsheets."}]
31:["$","p",null,{"children":"An effective overhead crane inspection program needs:"}]
32:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Automated scheduling"}]," — the system tracks when each crane is due for each type of inspection and sends alerts"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Mobile-friendly checklists"}]," — operators complete ",["$","$Le",null,{"href":"/blog/daily-crane-inspection-checklist","children":"daily checks"}]," on their phone, not a clipboard"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Photo documentation"}]," — deficiency photos attached to inspection records, timestamped and GPS-tagged"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Corrective action tracking"}]," — deficiencies found during inspection are tracked to resolution with due dates and assignments"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Audit-ready reports"}]," — one click to generate a compliance report showing every inspection for any crane over any time period"]}]]}]
33:["$","p",null,{"children":["This is exactly what ",["$","$Le",null,{"href":"/pricing","children":"CraneCheck"}]," is built to do. Every inspection type — daily, monthly, quarterly, annual — is tracked per crane with automated reminders, mobile checklists, photo capture, and instant report generation. No spreadsheets. No lost paper forms. No guessing when the last inspection was."]}]
34:["$","h2",null,{"children":"Key Takeaways"}]
35:["$","ul",null,{"children":[["$","li",null,{"children":"Pre-shift visual inspections are required every day the crane operates — no exceptions"}],["$","li",null,{"children":"Monthly frequent inspections cover wear items, safety devices, and operating mechanisms"}],["$","li",null,{"children":"Annual periodic inspections are the most comprehensive and must be documented in writing"}],["$","li",null,{"children":"ASME B30.2 is more detailed than OSHA 1910.179 — follow whichever is more stringent"}],["$","li",null,{"children":"Service classification (light through severe) determines your actual minimum intervals"}],["$","li",null,{"children":"Missing inspections creates both regulatory and legal liability exposure"}]]}]
