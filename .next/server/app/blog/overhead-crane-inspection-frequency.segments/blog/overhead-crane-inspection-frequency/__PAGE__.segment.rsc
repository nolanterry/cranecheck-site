0:{"buildId":"vuZ19Hjr3Kc9yxkX9VPdR","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","main",null,{"children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Compliance"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 8, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"12 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"Overhead Crane Inspection Frequency: OSHA vs ASME Requirements"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl","children":"How often should you inspect overhead cranes? The answer depends on which standard you follow, what type of service the crane sees, and whether your state enforces additional requirements. This guide breaks down every inspection interval."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-strong:text-navy","children":[["$","p",null,{"children":["Overhead cranes operate in factories, warehouses, steel mills, and fabrication shops across every industry. They lift heavy loads, often over workers, hundreds of times per day. The inspection frequency requirements for these cranes are governed by two overlapping frameworks: ",["$","strong",null,{"children":"OSHA 1910.179"}]," (federal regulation) and ",["$","strong",null,{"children":"ASME B30.2"}]," (consensus standard). Understanding both is not optional — it is the baseline for keeping your facility compliant and your workers alive."]}],["$","h2",null,{"children":"The Two Standards You Must Know"}],["$","p",null,{"children":"OSHA and ASME are not the same thing, and they do not always agree. Here is the critical distinction:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"OSHA 1910.179"}]," is a federal regulation. It is legally enforceable. Violations result in citations and fines. It applies to all overhead and gantry cranes in general industry."]}],["$","li",null,{"children":[["$","strong",null,{"children":"ASME B30.2"}]," is a voluntary consensus standard published by the American Society of Mechanical Engineers. It is more detailed and more frequently updated than the OSHA standard. Many states and insurance companies require compliance with ASME B30.2 even though it is not itself a federal regulation."]}]]}],["$","p",null,{"children":"In practice, you should follow whichever is more stringent. In almost every case, that is ASME B30.2. OSHA inspectors routinely reference ASME standards when evaluating compliance, and courts have upheld citations based on ASME best practices under the General Duty Clause."}],["$","h2",null,{"children":"Daily (Pre-Use) Inspections"}],["$","p",null,{"children":"Both OSHA and ASME require a visual inspection before each shift or each use of the crane. Under OSHA 1910.179(j)(2), operators must check for:"}],["$","ul",null,{"children":[["$","li",null,{"children":"All functional operating mechanisms for maladjustment interfering with proper operation"}],["$","li",null,{"children":"Deterioration or leakage in lines, tanks, valves, drain pumps, and other parts of air or hydraulic systems"}],["$","li",null,{"children":"Hooks with deformations or cracks (see ASME B30.10 for hook inspection criteria)"}],["$","li",null,{"children":"Hoist chains, including end connections, for excessive wear, twist, distorted links, or stretch"}],"$L3","$L4"]}],"$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21"]}]}],"$L22"]}],"$L23"],["$L24"],"$L25"]}],"loading":null,"isPartial":false}
3:["$","li",null,{"children":"All functional operating mechanisms for excessive wear of components"}]
4:["$","li",null,{"children":"Rope reeving for noncompliance with manufacturer recommendations"}]
5:["$","p",null,{"children":["ASME B30.2-2024 Section 2-2.2.2 categorizes these as ",["$","strong",null,{"children":"frequent inspections"}]," — items checked daily to monthly depending on crane service. For cranes in continuous or severe service, daily is the minimum. For cranes in normal or light service, the interval can extend to monthly for some items, but ",["$","strong",null,{"children":"pre-shift operational checks are always required"}],"."]}]
6:["$","h2",null,{"children":"Monthly (Frequent) Inspections"}]
7:["$","p",null,{"children":"ASME B30.2 defines frequent inspections as those performed at intervals of daily to monthly depending on the activity level of the crane. Monthly inspections should cover everything in the daily checklist plus:"}]
8:["$","ul",null,{"children":[["$","li",null,{"children":"Deterioration or leakage in lines, tanks, valves, drain pumps"}],["$","li",null,{"children":"Hooks — check latch engagement, throat opening measurement, twist exceeding 10 degrees"}],["$","li",null,{"children":"Hoist chains — check for stretch beyond manufacturer limits"}],["$","li",null,{"children":"Wire rope — check for broken wires, corrosion, kinking, crushing, bird-caging"}],["$","li",null,{"children":"All functional operating mechanisms for excessive component wear"}],["$","li",null,{"children":"Control and safety devices — verify limit switches, emergency stops function"}]]}]
9:["$","p",null,{"children":["Monthly inspections should be documented. While OSHA 1910.179 does not explicitly require written records for frequent inspections, ASME B30.2 does, and best practice is to always create a record. ",["$","$L26",null,{"href":"/blog/crane-inspection-software-vs-paper","children":"Digital inspection logs"}]," eliminate the ambiguity — every check is timestamped, signed, and stored."]}]
a:["$","h2",null,{"children":"Quarterly Inspections"}]
b:["$","p",null,{"children":"Neither OSHA 1910.179 nor ASME B30.2 explicitly defines a quarterly inspection tier. However, many facilities adopt quarterly intervals for items that fall between monthly and annual categories. Common quarterly inspection items include:"}]
c:["$","ul",null,{"children":[["$","li",null,{"children":"Wire rope replacement evaluation (measuring diameter reduction, broken wire count per lay length)"}],["$","li",null,{"children":"Brake adjustment and wear assessment"}],["$","li",null,{"children":"Electrical system checks — contactors, resistors, collector shoes"}],["$","li",null,{"children":"Runway and bridge alignment verification"}],["$","li",null,{"children":"Lubrication schedule compliance review"}]]}]
d:["$","p",null,{"children":"Quarterly inspections are a practical middle ground. Waiting a full year between periodic inspections for high-use cranes is risky. If your crane lifts rated capacity regularly or operates in a corrosive environment, quarterly checks on wear components are a defensible practice."}]
e:["$","h2",null,{"children":"Annual (Periodic) Inspections"}]
f:["$","p",null,{"children":"This is where the requirements get serious. Both OSHA and ASME require periodic inspections at intervals of one to twelve months depending on crane service. For most facilities, annual is the standard interval."}]
10:["$","p",null,{"children":"Under OSHA 1910.179(j)(3), periodic inspections must cover:"}]
11:["$","ul",null,{"children":[["$","li",null,{"children":"Deformed, cracked, or corroded members in the crane structure"}],["$","li",null,{"children":"Loose bolts or rivets"}],["$","li",null,{"children":"Cracked or worn sheaves and drums"}],["$","li",null,{"children":"Worn, cracked, or distorted parts such as pins, bearings, shafts, gears, rollers, locking and clamping devices"}],["$","li",null,{"children":"Excessive wear on brake system parts"}],["$","li",null,{"children":"Load, wind, and other indicators for inoperability"}],["$","li",null,{"children":"Gasoline, diesel, electric, or other power plants for improper performance"}],["$","li",null,{"children":"Excessive wear of chain drive sprocket and chain"}],["$","li",null,{"children":"Electrical apparatus for signs of pitting or deterioration of contacts, controllers, limit switches, and pushbutton stations"}],["$","li",null,{"children":"Travel, trolley, and bridge bumpers"}]]}]
12:["$","p",null,{"children":["ASME B30.2 Section 2-2.2.3 expands this list significantly and requires that periodic inspections be performed by a ",["$","strong",null,{"children":"designated person"}]," — someone who is qualified by knowledge, training, and experience to perform the inspection."]}]
13:["$","p",null,{"children":[["$","strong",null,{"children":"Annual inspections must be documented."}]," Both OSHA and ASME require written records. These records must include: the date, the items inspected, the condition of each item, the name of the inspector, and any corrective actions taken. This is non-negotiable. If you cannot produce these records during an OSHA audit, you will be cited."]}]
14:["$","h2",null,{"children":"Inspection Frequency by Service Classification"}]
15:["$","p",null,{"children":"ASME B30.2 categorizes crane service into classes that affect inspection frequency:"}]
16:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Standby or infrequent service"}]," — crane sits idle for long periods, used infrequently. Inspect before each use; periodic inspection annually minimum."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Light service"}]," — loads well below rated capacity, 2-5 lifts per hour. Monthly frequent inspections; annual periodic inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Moderate service"}]," — loads average 50% of rated capacity, 5-10 lifts per hour. Monthly frequent inspections; semi-annual periodic inspections recommended."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Heavy service"}]," — loads approaching rated capacity, 10-20 lifts per hour. Weekly frequent inspections; semi-annual periodic inspections."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Severe service"}]," — rated capacity loads throughout lifecycle, 20+ lifts per hour. Daily frequent inspections; quarterly periodic inspections."]}]]}]
17:["$","p",null,{"children":"Most facilities underestimate their service classification. A steel service center lifting coils all day is severe service, not moderate. A precast concrete plant running a 50-ton crane at capacity is severe. Classify honestly — it determines your minimum inspection intervals."}]
18:["$","h2",null,{"children":"What Happens When You Miss an Inspection"}]
19:["$","p",null,{"children":["OSHA penalties for crane inspection violations under 1910.179 range from ",["$","strong",null,{"children":"$$16,131 per serious violation"}]," to ",["$","strong",null,{"children":"$$161,323 per willful violation"}]," (2024 penalty amounts, adjusted annually). Missing a required annual inspection is typically cited as serious. Missing inspections after a known deficiency can escalate to willful."]}]
1a:["$","p",null,{"children":["Beyond fines, the real cost is liability. If a crane fails and your inspection records show a gap, plaintiff attorneys will use that gap to establish negligence. Documented, consistent inspections are your first line of defense in any incident investigation. See our guide on ",["$","$L26",null,{"href":"/blog/crane-inspection-penalties-fines","children":"OSHA crane penalties and fines"}]," for a full breakdown."]}]
1b:["$","h2",null,{"children":"Building an Inspection Schedule That Works"}]
1c:["$","p",null,{"children":"The most common failure is not a lack of knowledge — it is a lack of systems. Safety directors know the requirements. The problem is tracking dozens of cranes across multiple intervals with paper forms and spreadsheets."}]
1d:["$","p",null,{"children":"An effective overhead crane inspection program needs:"}]
1e:["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Automated scheduling"}]," — the system tracks when each crane is due for each type of inspection and sends alerts"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Mobile-friendly checklists"}]," — operators complete ",["$","$L26",null,{"href":"/blog/daily-crane-inspection-checklist","children":"daily checks"}]," on their phone, not a clipboard"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Photo documentation"}]," — deficiency photos attached to inspection records, timestamped and GPS-tagged"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Corrective action tracking"}]," — deficiencies found during inspection are tracked to resolution with due dates and assignments"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Audit-ready reports"}]," — one click to generate a compliance report showing every inspection for any crane over any time period"]}]]}]
1f:["$","p",null,{"children":["This is exactly what ",["$","$L26",null,{"href":"/pricing","children":"CraneCheck"}]," is built to do. Every inspection type — daily, monthly, quarterly, annual — is tracked per crane with automated reminders, mobile checklists, photo capture, and instant report generation. No spreadsheets. No lost paper forms. No guessing when the last inspection was."]}]
20:["$","h2",null,{"children":"Key Takeaways"}]
21:["$","ul",null,{"children":[["$","li",null,{"children":"Pre-shift visual inspections are required every day the crane operates — no exceptions"}],["$","li",null,{"children":"Monthly frequent inspections cover wear items, safety devices, and operating mechanisms"}],["$","li",null,{"children":"Annual periodic inspections are the most comprehensive and must be documented in writing"}],["$","li",null,{"children":"ASME B30.2 is more detailed than OSHA 1910.179 — follow whichever is more stringent"}],["$","li",null,{"children":"Service classification (light through severe) determines your actual minimum intervals"}],["$","li",null,{"children":"Missing inspections creates both regulatory and legal liability exposure"}]]}]
22:["$","section",null,{"className":"bg-navy py-16 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto text-center","children":[["$","h2",null,{"className":"text-2xl md:text-3xl font-bold text-white mb-4","children":"Never Miss an Inspection Deadline Again"}],["$","p",null,{"className":"text-gray-300 mb-8 max-w-xl mx-auto","children":"CraneCheck tracks every crane, every inspection type, every interval — automatically. See it in action."}],["$","$L26",null,{"href":"/pricing","className":"bg-brand hover:bg-brand-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors","children":"Start Free Trial →"}]]}]}]
