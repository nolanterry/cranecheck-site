a:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"ConExpo 2026: Why Crane Inspection Is Finally Going Digital\",\"description\":\"ConExpo-CON/AGG 2026 showcased the future of crane technology. But while OEMs push telematics and AI, most crane companies still track inspections on paper. Here's why that's about to change.\",\"datePublished\":\"2026-03-09\",\"dateModified\":\"2026-03-09\",\"author\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"CraneCheck\",\"url\":\"https://cranecheck.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://cranecheck.com/blog/conexpo-2026-crane-inspection-technology\"}}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://cranecheck.com\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://cranecheck.com/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"ConExpo 2026: Why Crane Inspection Is Finally Going Digital\",\"item\":\"https://cranecheck.com/blog/conexpo-2026-crane-inspection-technology\"}]}"}}],["$","$L13",null,{}],["$","$L14",null,{}],["$","main",null,{"id":"main-content","children":[["$","section",null,{"className":"bg-gradient-to-br from-navy via-navy-light to-navy py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex items-center gap-3 mb-6","children":[["$","span",null,{"className":"text-xs font-medium text-brand bg-brand-light px-2.5 py-1 rounded-full","children":"Industry"}],["$","span",null,{"className":"text-xs text-gray-400","children":"March 9, 2026"}],["$","span",null,{"className":"text-xs text-gray-400","children":"8 min read"}]]}],["$","h1",null,{"className":"text-3xl md:text-5xl font-bold mb-6 text-white leading-tight","children":"ConExpo 2026: Why Crane Inspection Is Finally Going Digital"}],["$","p",null,{"className":"text-lg text-gray-300 max-w-2xl","children":"ConExpo-CON/AGG 2026 is showcasing the most advanced crane technology ever built. Electric cranes. AI-assisted load planning. Real-time telematics. But walk into most crane companies' offices and you'll still find inspection records in three-ring binders. That disconnect is closing fast."}]]}]}],["$","article",null,{"className":"py-16 bg-white","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 prose prose-lg prose-gray prose-headings:text-navy prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-strong:text-navy","children":[["$","div",null,{"className":"not-prose","children":["$","$L15",null,{}]}],["$","p",null,{"children":"Every three years, ConExpo-CON/AGG brings the construction industry together in Las Vegas to see the future. And in 2026, the future is unmistakable: cranes are getting smarter, more connected, and more data-rich than ever before."}],["$","p",null,{"children":"Manufacturers like Liebherr, Manitowoc, and Tadano are showcasing cranes with integrated telematics, real-time load monitoring, predictive maintenance alerts, and even electric powertrains. LiuGong presented 13 machines focused on electrification and integrated digital solutions. The hardware is advancing at an incredible pace."}],["$","p",null,{"children":["But there's a gap that ConExpo doesn't showcase on the show floor: ",["$","strong",null,{"children":"the inspection and compliance workflows that keep these machines legal to operate"}],". And for most crane companies, those workflows haven't changed in decades."]}],"$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d"]}]}],"$L2e","$L2f"]}],"$L30"],["$L31","$L32"],"$L33"]}]
