0:{"buildId":"f-wLp3UizMU5tGDgsHayP","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","main",null,{"id":"main-content","className":"py-20 bg-white","children":["$","article",null,{"className":"max-w-3xl mx-auto px-4 prose prose-gray","children":[["$","h1",null,{"children":"Privacy Policy"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last updated: March 15, 2026"}],["$","p",null,{"children":"CraneCheck (\"we,\" \"us,\" or \"our\") operates the CraneCheck crane inspection compliance platform. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you use our website and application."}],["$","h2",null,{"children":"1. Information We Collect"}],["$","h3",null,{"children":"Information You Provide"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Account information:"}]," Name, email address, company name, phone number, and job title when you create an account or request a demo."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Inspection data:"}]," Crane inspection records, photos, deficiency notes, equipment details, and compliance documentation you enter into the platform."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Payment information:"}]," Billing address and payment method details, processed securely by our payment processor (Stripe). We do not store full credit card numbers."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Communications:"}]," Messages you send through our contact form, support tickets, or email correspondence."]}]]}],["$","h3",null,{"children":"Information Collected Automatically"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Usage data:"}]," Pages visited, features used, inspection completion patterns, and session duration."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Device information:"}]," Browser type, operating system, device type, screen resolution, and IP address."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cookies and similar technologies:"}]," We use essential cookies for authentication and optional analytics cookies to improve our service."]}]]}],["$","h2",null,{"children":"2. How We Use Your Information"}],["$","ul",null,{"children":[["$","li",null,{"children":"Provide, maintain, and improve the CraneCheck platform"}],["$","li",null,{"children":"Process transactions and send related information (receipts, invoices)"}],["$","li",null,{"children":"Send technical notices, updates, security alerts, and support messages"}],["$","li",null,{"children":"Respond to your comments, questions, and support requests"}],["$","li",null,{"children":"Monitor and analyze usage trends to improve user experience"}],["$","li",null,{"children":"Detect, prevent, and address technical issues and fraud"}],["$","li",null,{"children":"Send marketing communications (with your consent; you can opt out anytime)"}]]}],["$","h2",null,{"children":"3. Data Sharing and Disclosure"}],["$","p",null,{"children":"We do not sell your personal information. We may share data with:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Service providers:"}]," Third-party vendors who assist in operating our platform (hosting, payment processing, email delivery, analytics)."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal compliance:"}]," When required by law, regulation, or legal process."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Business transfers:"}]," In connection with a merger, acquisition, or sale of assets."]}],["$","li",null,{"children":[["$","strong",null,{"children":"With your consent:"}]," When you explicitly authorize sharing."]}]]}],["$","h2",null,{"children":"4. Data Security"}],["$","p",null,{"children":"We implement industry-standard security measures including encryption in transit (TLS 1.2+), encryption at rest, access controls, and regular security assessments. Inspection data and compliance records are stored in SOC 2-compliant infrastructure."}],"$L3","$L4","$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld"]}]}],"$Le"],["$Lf"],"$L10"]}],"loading":null,"isPartial":false}
3:["$","h2",null,{"children":"5. Data Retention"}]
4:["$","p",null,{"children":"We retain your account information and inspection data for as long as your account is active or as needed to provide services. Inspection records may be retained longer to support OSHA compliance requirements (typically 5+ years per 29 CFR 1926.1412). You may request deletion of your data at any time, subject to legal retention requirements."}]
5:["$","h2",null,{"children":"6. Your Rights"}]
6:["$","p",null,{"children":"Depending on your jurisdiction, you may have the right to:"}]
7:["$","ul",null,{"children":[["$","li",null,{"children":"Access the personal data we hold about you"}],["$","li",null,{"children":"Correct inaccurate or incomplete data"}],["$","li",null,{"children":"Request deletion of your data"}],["$","li",null,{"children":"Object to or restrict processing of your data"}],["$","li",null,{"children":"Export your data in a portable format"}],["$","li",null,{"children":"Withdraw consent for marketing communications"}]]}]
8:["$","h2",null,{"children":"7. Children's Privacy"}]
9:["$","p",null,{"children":"CraneCheck is not intended for use by individuals under 18 years of age. We do not knowingly collect personal information from children."}]
a:["$","h2",null,{"children":"8. Changes to This Policy"}]
b:["$","p",null,{"children":"We may update this Privacy Policy from time to time. We will notify you of material changes by posting the updated policy on this page and updating the \"Last updated\" date."}]
c:["$","h2",null,{"children":"9. Contact Us"}]
d:["$","p",null,{"children":["If you have questions about this Privacy Policy or your data, contact us at:"," ",["$","a",null,{"href":"mailto:support@cranecheck.com","children":"support@cranecheck.com"}]]}]
