8:["$","$1","c",{"children":[[["$","$L10",null,{}],["$","main",null,{"id":"main-content","className":"py-20 bg-white","children":["$","article",null,{"className":"max-w-3xl mx-auto px-4 prose prose-gray","children":[["$","h1",null,{"children":"Terms of Service"}],["$","p",null,{"className":"text-sm text-gray-500","children":"Last updated: March 15, 2026"}],["$","p",null,{"children":"These Terms of Service (\"Terms\") govern your access to and use of CraneCheck's crane inspection compliance platform, including our website, applications, and services (collectively, the \"Service\"). By using the Service, you agree to these Terms."}],["$","h2",null,{"children":"1. Account Registration"}],["$","p",null,{"children":"You must create an account to use CraneCheck. You are responsible for maintaining the confidentiality of your account credentials and for all activities under your account. You must provide accurate, current, and complete information during registration."}],["$","h2",null,{"children":"2. Subscription and Payment"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Free trial:"}]," New accounts receive a 14-day free trial with full access to all features. No credit card is required to start."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Billing:"}]," After the trial, continued access requires an active paid subscription. Subscriptions are billed monthly or annually as selected."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cancellation:"}]," You may cancel your subscription at any time. Access continues through the end of your current billing period. No refunds are issued for partial billing periods."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Price changes:"}]," We may adjust pricing with 30 days' notice. Existing subscribers are locked into their current rate until their next renewal cycle."]}]]}],["$","h2",null,{"children":"3. Acceptable Use"}],["$","p",null,{"children":"You agree not to:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Use the Service for any unlawful purpose"}],["$","li",null,{"children":"Share your account credentials with unauthorized parties"}],["$","li",null,{"children":"Attempt to reverse-engineer, decompile, or disassemble the Service"}],["$","li",null,{"children":"Upload malicious code, viruses, or harmful content"}],["$","li",null,{"children":"Interfere with the security or integrity of the Service"}],["$","li",null,{"children":"Scrape, crawl, or use automated tools to extract data from the Service"}]]}],["$","h2",null,{"children":"4. Your Data"}],["$","p",null,{"children":"You retain ownership of all inspection data, photos, reports, and other content you create or upload to CraneCheck (\"Your Data\"). You grant us a limited license to host, store, and process Your Data solely to provide and improve the Service. We will not share Your Data with third parties except as described in our Privacy Policy."}],["$","h2",null,{"children":"5. Data Export"}],["$","p",null,{"children":"You may export Your Data at any time in standard formats (PDF reports, CSV data exports). Upon account termination, you will have 30 days to export Your Data before it is permanently deleted."}],["$","h2",null,{"children":"6. Service Availability"}],["$","p",null,{"children":"We strive for high availability but do not guarantee uninterrupted service. We may perform scheduled maintenance with advance notice. We are not liable for temporary service interruptions due to maintenance, updates, or circumstances beyond our control."}],["$","h2",null,{"children":"7. Disclaimer of Warranties"}],["$","p",null,{"children":"CraneCheck is provided \"as is\" and \"as available.\" While we design our platform to support OSHA compliance workflows (29 CFR 1926 Subpart CC), CraneCheck is a tool to assist your compliance processes — it does not constitute legal advice and does not guarantee regulatory compliance. You remain responsible for ensuring your inspection programs meet applicable federal, state, and local requirements."}],"$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c"]}]}],"$L1d"],["$L1e"],"$L1f"]}]
