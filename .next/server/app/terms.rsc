a:["$","p",null,{"children":"You retain ownership of all inspection data, photos, reports, and other content you create or upload to CraneCheck (\"Your Data\"). You grant us a limited license to host, store, and process Your Data solely to provide and improve the Service. We will not share Your Data with third parties except as described in our Privacy Policy."}]
b:["$","h2",null,{"children":"5. Data Export"}]
c:["$","p",null,{"children":"You may export Your Data at any time in standard formats (PDF reports, CSV data exports). Upon account termination, you will have 30 days to export Your Data before it is permanently deleted."}]
d:["$","h2",null,{"children":"6. Service Availability"}]
e:["$","p",null,{"children":"We strive for high availability but do not guarantee uninterrupted service. We may perform scheduled maintenance with advance notice. We are not liable for temporary service interruptions due to maintenance, updates, or circumstances beyond our control."}]
f:["$","h2",null,{"children":"7. Disclaimer of Warranties"}]
10:["$","p",null,{"children":"CraneCheck is provided \"as is\" and \"as available.\" While we design our platform to support OSHA compliance workflows (29 CFR 1926 Subpart CC), CraneCheck is a tool to assist your compliance processes — it does not constitute legal advice and does not guarantee regulatory compliance. You remain responsible for ensuring your inspection programs meet applicable federal, state, and local requirements."}]
11:["$","h2",null,{"children":"8. Limitation of Liability"}]
12:["$","p",null,{"children":"To the maximum extent permitted by law, CraneCheck's total liability for any claims arising from or related to the Service shall not exceed the amount you paid us in the 12 months preceding the claim. We are not liable for indirect, incidental, consequential, or punitive damages, including lost profits, data loss, or business interruption."}]
13:["$","h2",null,{"children":"9. Indemnification"}]
14:["$","p",null,{"children":"You agree to indemnify and hold harmless CraneCheck and its officers, employees, and agents from any claims, damages, or expenses arising from your use of the Service or violation of these Terms."}]
15:["$","h2",null,{"children":"10. Termination"}]
16:["$","p",null,{"children":"We may suspend or terminate your account if you violate these Terms or engage in conduct that may harm our platform or other users. You may terminate your account at any time through your account settings or by contacting support."}]
17:["$","h2",null,{"children":"11. Changes to Terms"}]
18:["$","p",null,{"children":"We may update these Terms from time to time. We will notify you of material changes via email or in-app notification at least 30 days before they take effect. Continued use of the Service after changes take effect constitutes acceptance."}]
19:["$","h2",null,{"children":"12. Governing Law"}]
